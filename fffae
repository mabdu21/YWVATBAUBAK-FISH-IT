            if track and AP.seenTracks[track] then return end
            if track then AP.seenTracks[track] = true end
            local anim = track and track.Animation
            local id = anim and tostring(anim.AnimationId) or ""
            parryFromAnim(char, id, track)
        end)
    end)
end

