    if not force and now-GEN.lastGuiScanAt<GEN.guiScanDelay then return nil,nil end
    GEN.lastGuiScanAt=now
    GEN.cachedSkillGui=nil; GEN.cachedSkillCheck=nil
    gui,check=getSkillGui()
    if check and check.Parent and isVisibleGui(check) and isVisibleGui(gui) then return check,gui end
    return nil,nil
end

