local function destroyParryRangePart()
    if AP.rangeConn then pcall(function() AP.rangeConn:Disconnect() end); AP.rangeConn = nil end
    if AP.rangePart then pcall(function() AP.rangePart:Destroy() end); AP.rangePart = nil end
end

local function ensureParryRangePart()
    if not _G.ShowParryRange then destroyParryRangePart(); return end
    if not AP.rangePart or not AP.rangePart.Parent then
        local part = Instance.new("Part")
        part.Name = "DYHUB_ParryRangeCircle"
        part.Anchored = true
        part.CanCollide = false
        part.CanTouch = false
        part.CanQuery = false
        part.CastShadow = false
        part.Shape = Enum.PartType.Cylinder
        part.Material = Enum.Material.SmoothPlastic
        part.Color = Color3.fromRGB(255, 255, 255)
        part.Transparency = 0.9
        part.TopSurface = Enum.SurfaceType.Smooth
        part.BottomSurface = Enum.SurfaceType.Smooth
        part.Locked = true
        part.Parent = Workspace
        AP.rangePart = part
    end
    if not AP.rangeConn then
        local acc = 0
        AP.rangeConn = RunService.Heartbeat:Connect(function(dt)
            if not _G.ShowParryRange then destroyParryRangePart(); return end
            acc += dt
            if acc < 0.045 then return end
            acc = 0
            local r = myRoot()
            local part = AP.rangePart
            if not r or not part or not part.Parent then return end
            local range = math.clamp(tonumber(_G.AutoParryRange) or 10, 1, 80)

            -- Fix: place the circle on the ground/under the feet, not around the legs.
            local y
            local char = myChar()
            local okRay, rayResult = pcall(function()
                local params = RaycastParams.new()
                pcall(function()
                    params.FilterType = Enum.RaycastFilterType.Exclude
                end)
                pcall(function()
                    if params.FilterType ~= Enum.RaycastFilterType.Exclude then
                        params.FilterType = Enum.RaycastFilterType.Blacklist
                    end
                end)
                params.IgnoreWater = true
                local ignoreList = { part }
                if char then table.insert(ignoreList, char) end
                params.FilterDescendantsInstances = ignoreList
                return Workspace:Raycast(r.Position + Vector3.new(0, 2, 0), Vector3.new(0, -14, 0), params)
            end)

            if okRay and rayResult then
                y = rayResult.Position.Y + 0.045
            elseif char then
                local okBox, cf, size = pcall(function()
                    local boxCf, boxSize = char:GetBoundingBox()
                    return boxCf, boxSize
                end)
                if okBox and cf and size then
                    y = (cf.Position.Y - (size.Y / 2)) + 0.045
                end
            end

            y = y or (r.Position.Y - 3)
            part.Size = Vector3.new(0.08, range * 2, range * 2)
            part.CFrame = CFrame.new(r.Position.X, y, r.Position.Z) * CFrame.Angles(0, 0, math.rad(90))
        end)
    end
end

