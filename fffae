    if obj:IsA("ScreenGui") then
        local ok,en=pcall(function() return obj.Enabled end)
        return (not ok) or en~=false
    end
    if obj:IsA("GuiObject") then
        local ok,vis=pcall(function() return obj.Visible end)
        return ok and vis==true
    end
    return false
end

