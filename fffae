        for _,d in ipairs(ReplicatedStorage:GetDescendants()) do
            if d.Name=="SkillCheckResultEvent" and d:IsA("RemoteEvent") then skillRemote=d end
            if d.Name=="RepairEvent" and d:IsA("RemoteEvent") then repairRemote=d end
        end
