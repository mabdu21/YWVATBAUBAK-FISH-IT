    if gui and gui.Parent and gui:IsA("GuiObject") then pcall(function() gui.Visible=false end) end
    if gui and gui.Parent then
        for _,d in ipairs(gui:GetDescendants()) do
            if d.Name=="Check" and d:IsA("GuiObject") then pcall(function() d.Visible=false end) end
        end
