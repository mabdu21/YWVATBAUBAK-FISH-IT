-- =====================================================================================
--  AUTO LEVERS (NO HOLD) SYSTEM
--  Logic: near ExitLever.Main -> ProgressPromptGui.Frame visible -> LeverEvent(Main,true)
--  Cancel: movement/WASD/joystick/X -> LeverEvent(Main,false)
--  Wrapped in installer to avoid Luau local-register limit.
-- =====================================================================================
do
local function installAutoLevers()
    local LEV = {
        thread=nil, remote=nil, cache={}, cacheDirty=true, invalidateQueued=false,
        cachedGui=nil, cachedFrame=nil, lastGuiScanAt=0, lastScanAt=0, lastFireAt=0, lastMoveCheckAt=0,
        activeMain=nil, lastRootPos=nil, db=false, cancelDB=false, suppressUntil=0,
        nearDistance=10.5, scanDelay=2.0, loopDelay=0.075, guiScanDelay=0.12, refireDelay=0.75,
    }

    local function resolveLeverRemote()
        if LEV.remote and LEV.remote.Parent then return true end
        local remotes=ReplicatedStorage:FindFirstChild("Remotes")
        local exitFolder=remotes and remotes:FindFirstChild("Exit")
        LEV.remote=exitFolder and exitFolder:FindFirstChild("LeverEvent")
        if not LEV.remote then
            for _,d in ipairs(ReplicatedStorage:GetDescendants()) do
                if d.Name=="LeverEvent" and d:IsA("RemoteEvent") then LEV.remote=d; break end
            end
        end
        return LEV.remote~=nil
    end

    local function clearLeverCache()
        clearTable(LEV.cache)
        LEV.cacheDirty=true
        LEV.lastScanAt=0
    end

    local function scheduleLeverInvalidate()
        if LEV.invalidateQueued then return end
        LEV.invalidateQueued=true
        task.delay(1.0,function()
            LEV.invalidateQueued=false
            clearLeverCache()
        end)
    end

    local function getLeverMainFromModel(model)
        if not model or not model.Parent then return nil end
        local main=model:FindFirstChild("Main") or model:FindFirstChild("Main",true)
        if main and main:IsA("BasePart") then return main end
        if main and main:IsA("Model") then return getAnyBasePart(main) end
        return nil
    end

    local function rebuildLeverCache(force)
        local now=os.clock()
        if not force and not LEV.cacheDirty and now-LEV.lastScanAt<LEV.scanDelay then return end
        LEV.cacheDirty=false
        LEV.lastScanAt=now
        clearTable(LEV.cache)
        local map=Workspace:FindFirstChild("Map")
        local root=map or Workspace
        for _,d in ipairs(root:GetDescendants()) do
            if d:IsA("Model") and d.Name=="ExitLever" then
                local main=getLeverMainFromModel(d)
                if main then LEV.cache[#LEV.cache+1]=main end
            end
        end
    end

    local function getNearestLeverMain(maxDist)
        local char=LocalPlayer.Character
        local root=getRoot(char)
        if not root then return nil,math.huge end
        rebuildLeverCache(false)
        if #LEV.cache==0 then rebuildLeverCache(true) end
        local best,bd=nil,math.huge
        local limit=maxDist or LEV.nearDistance
        for i=#LEV.cache,1,-1 do
            local main=LEV.cache[i]
            if not main or not main.Parent then
                table.remove(LEV.cache,i)
            else
                local dist=(root.Position-main.Position).Magnitude
                if dist<bd and dist<=limit then best,bd=main,dist end
            end
        end
        return best,bd
    end

    local function getProgressFrame(force)
        local now=os.clock()
        local pg=LocalPlayer:FindFirstChild("PlayerGui")
        if not pg then return nil,nil end
        if not force and LEV.cachedFrame and LEV.cachedFrame.Parent and now-LEV.lastGuiScanAt<LEV.guiScanDelay then
            return LEV.cachedFrame,LEV.cachedGui
        end
        LEV.lastGuiScanAt=now
        local gui=LEV.cachedGui
        if not gui or not gui.Parent then
            gui=pg:FindFirstChild("ProgressPromptGui") or pg:FindFirstChild("ProgressPromptGui",true)
        end
        local frame=LEV.cachedFrame
        if not frame or not frame.Parent then
            frame=gui and (gui:FindFirstChild("Frame") or gui:FindFirstChild("Frame",true))
        end
        LEV.cachedGui=gui
        LEV.cachedFrame=frame
        return frame,gui
    end

    local function isProgressVisible()
        local frame,gui=getProgressFrame(false)
        if not frame or not frame.Parent then return false end
        if gui and gui:IsA("ScreenGui") then
            local ok,en=pcall(function() return gui.Enabled end)
            if ok and en==false then return false end
        elseif gui and gui:IsA("GuiObject") then
            local ok,vis=pcall(function() return gui.Visible end)
            if ok and vis==false then return false end
        end
        local ok,vis=pcall(function() return frame.Visible end)
        return (not ok) or vis==true
    end

    local function fireLever(main,hold)
        if not main or not main.Parent then return false end
        if not resolveLeverRemote() then return false end
        return pcall(function()
            LEV.remote:FireServer(main,hold==true)
        end)
    end

    local function cancelLever(reason)
        if LEV.cancelDB then return end
        local main=LEV.activeMain
        if not main or not main.Parent then
            main=select(1,getNearestLeverMain(LEV.nearDistance+2))
        end
        if not main then return end
        LEV.cancelDB=true
        LEV.suppressUntil=os.clock()+0.35
        fireLever(main,false)
        LEV.activeMain=nil
        task.delay(0.22,function() LEV.cancelDB=false end)
        if reason=="manual" then notify("Auto Levers | Cancelled","Exit lever action cancelled.","x") end
    end

    local function detectLeverMove()
        local now=os.clock()
        if now<LEV.suppressUntil or now-LEV.lastMoveCheckAt<0.08 then return false end
        LEV.lastMoveCheckAt=now
        local char=LocalPlayer.Character
        local root=getRoot(char)
        local hum=char and char:FindFirstChildOfClass("Humanoid")
        if not root or not hum then return false end
        if hum.MoveDirection.Magnitude>0.18 then return true end
        local prev=LEV.lastRootPos
        LEV.lastRootPos=root.Position
        return prev and (root.Position-prev).Magnitude>1.85 and os.clock()-GEN.lastTeleportAt>0.75 and not GEN.isTweening
    end

    local function stepLever()
        if not settings.AutoLeversNoHold then return end
        if detectLeverMove() then
            if LEV.activeMain or isProgressVisible() then cancelLever("move") end
            return
        end
        if not isProgressVisible() then
            LEV.activeMain=nil
            return
        end
        local main=getNearestLeverMain(LEV.nearDistance)
        if not main then return end
        local now=os.clock()
        if LEV.db or now<LEV.suppressUntil then return end
        if LEV.activeMain==main and now-LEV.lastFireAt<LEV.refireDelay then return end
        LEV.db=true
        LEV.lastFireAt=now
        if fireLever(main,true) then
            LEV.activeMain=main
        end
        task.delay(0.10,function() LEV.db=false end)
    end

    local function leverThreadAlive()
        if not LEV.thread then return false end
        local ok,status=pcall(coroutine.status,LEV.thread)
        return ok and status~="dead"
    end

    local function startLeverLoop()
        if leverThreadAlive() then return end
        LEV.thread=task.spawn(function()
            while settings.AutoLeversNoHold do
                task.wait(LEV.loopDelay)
                pcall(stepLever)
            end
            LEV.thread=nil
        end)
    end

    local function stopLeverLoop()
        if LEV.thread then task.cancel(LEV.thread); LEV.thread=nil end
        cancelLever("off")
        LEV.activeMain=nil
    end

    local function bootAutoLever(reason)
        if not settings.AutoLeversNoHold then return end
        clearLeverCache()
        LEV.cachedGui=nil; LEV.cachedFrame=nil; LEV.lastGuiScanAt=0
        pcall(resolveLeverRemote)
        startLeverLoop()
        task.defer(function()
            if settings.AutoLeversNoHold then pcall(stepLever) end
        end)
    end

    local function isProgressPromptObj(obj)
        if not obj then return false end
        if obj.Name=="ProgressPromptGui" then return true end
        local cur=obj.Parent
        while cur and cur~=PlayerGui do
            if cur.Name=="ProgressPromptGui" then return true end
            cur=cur.Parent
        end
        return false
    end

    Workspace.DescendantAdded:Connect(function(obj)
        local n=lowerName(obj)
        if n=="exitlever" or (n=="main" and obj.Parent and obj.Parent.Name=="ExitLever") then scheduleLeverInvalidate() end
    end)
    Workspace.DescendantRemoving:Connect(function(obj)
        local n=lowerName(obj)
        if n=="exitlever" or (n=="main" and obj.Parent and obj.Parent.Name=="ExitLever") then scheduleLeverInvalidate() end
    end)
    PlayerGui.DescendantAdded:Connect(function(obj)
        if obj.Name=="ProgressPromptGui" or (obj.Name=="Frame" and isProgressPromptObj(obj)) then
            LEV.cachedGui=nil; LEV.cachedFrame=nil; LEV.lastGuiScanAt=0
            if settings.AutoLeversNoHold then task.defer(function() bootAutoLever("gui_added") end) end
        end
    end)
    UserInputService.InputBegan:Connect(function(input,gpe)
        if gpe then return end
        if input.KeyCode==Enum.KeyCode.X then
            if settings.AutoLeversNoHold then cancelLever("manual") end
            return
        end
        local moveKeys={
            [Enum.KeyCode.W]=true,[Enum.KeyCode.A]=true,[Enum.KeyCode.S]=true,[Enum.KeyCode.D]=true,
            [Enum.KeyCode.Up]=true,[Enum.KeyCode.Down]=true,[Enum.KeyCode.Left]=true,[Enum.KeyCode.Right]=true,[Enum.KeyCode.Space]=true,
        }
        if settings.AutoLeversNoHold and moveKeys[input.KeyCode] and (LEV.activeMain or isProgressVisible()) then cancelLever("move") end
    end)

    LocalPlayer.CharacterAdded:Connect(function()
        LEV.lastRootPos=nil
        LEV.activeMain=nil
        LEV.suppressUntil=os.clock()+0.80
        task.delay(1,function() bootAutoLever("character") end)
    end)

    task.spawn(function()
        while task.wait(0.8) do
            if settings.AutoLeversNoHold and not leverThreadAlive() then bootAutoLever("watchdog") end
        end
    end)

    SurTab:Section({ Title="Feature Exit", Icon="door-open" })
    SurTab:Toggle({
        Title="Auto Levers (No Hold)",
        Desc="Automatically presses the nearest exit levers.",
        Value=settings.AutoLeversNoHold,
        Callback=function(v)
            settings.AutoLeversNoHold=v
            Config:Set("AutoLeversNoHold",v)
            if v then
                Config:Save()
                bootAutoLever("toggle")
                notify("Auto Levers | Enabled","Stand near Lever, Move/WASD or press X to cancel.","door-open")
            else
                Config:Save()
                stopLeverLoop()
                notify("Auto Levers | Disabled","Auto lever system stopped.","door-closed")
            end
        end
    })

    if settings.AutoLeversNoHold then task.delay(1,function() bootAutoLever("initial") end) end
end
installAutoLevers()
end

