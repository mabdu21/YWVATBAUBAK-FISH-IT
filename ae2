-- MACRO FILE OPS
-- ============================================================
local function listMacros()
    local macros = {}
    pcall(function()
        if listfiles then
            for _, fp in ipairs(listfiles(MacroFolder)) do
                if fp:match("%.json$") then
                    local name = fp:match("([^/\\]+)%.json$")
                    if name then table.insert(macros, name) end
                end
            end
        end
    end)
    table.sort(macros)
    return macros
end

local function getNextAutoName()
    local existing = listMacros()
    local maxNum = 0
    for _, n in ipairs(existing) do
        local num = n:match("^DYHUB_MACRO_(%d+)$")
        if num then local v = tonumber(num); if v and v > maxNum then maxNum = v end end
    end
    return string.format("DYHUB_MACRO_%d", maxNum + 1)
end

local function ensureUniqueName(name)
    local existing = listMacros()
    if not table.find(existing, name) then return name end
    local base, counter = name, 1
    while table.find(existing, name) and counter < 999 do
        name = base .. "_" .. counter; counter = counter + 1
    end
    return name
end

local function saveMacroToFile(name, data)
    local safeName = name:gsub("[^%w_%-]", "_")
    if safeName == "" or safeName:match("^_+$") then return false, "Invalid name" end
    local path = MacroFolder .. "/" .. safeName .. ".json"
    local ok, err = pcall(function() writefile(path, HttpService:JSONEncode(data)) end)
    return ok, err
end

local function loadMacroFromFile(name)
    local safeName = name:gsub("[^%w_%-]", "_")
    local path = MacroFolder .. "/" .. safeName .. ".json"
    if not isfile(path) then return nil end
    local ok, data = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
    if ok and type(data) == "table" then return data end
    return nil
end

local function deleteMacroFile(name)
    local safeName = name:gsub("[^%w_%-]", "_")
    local path = MacroFolder .. "/" .. safeName .. ".json"
    pcall(function() delfile(path) end)
end

