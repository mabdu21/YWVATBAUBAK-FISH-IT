-- ============================================================
local function findGameIdByOrder(order) return orderToGameId[order] end

local function findOrderByCFrame(cframeData, tolerance)
    tolerance = tolerance or 3
    if not cframeData then return nil end
    local x, z = cframeData[1], cframeData[3]
    for order, gid in pairs(orderToGameId) do
        local cf = gameIdToCFrame[gid]
        if cf and typeof(cf) == "CFrame" then
            local p = cf.Position
            if math.abs(p.X - x) < tolerance and math.abs(p.Z - z) < tolerance then
                return order
            end
        end
    end
    return nil
end

local function playbackMacro(macroData)
    -- ★ FIX: ตรวจสอบ operations ก่อน
    if not macroData then
        WindUI:Notify({ Title = "Error", Content = "Macro data is nil!", Duration = 3, Icon = "x-octagon" })
        return
    end
    
    -- รองรับทั้ง .operations และ .ops (fallback)
    local operations = macroData.operations or macroData.ops
    if not operations or type(operations) ~= "table" or #operations == 0 then
        -- ลองดู macro นี้อาจมี format เก่า
        WindUI:Notify({ 
            Title = "Error", 
            Content = string.format("No operations in macro! Found: %d", operations and #operations or 0), 
            Duration = 4, 
            Icon = "x-octagon" 
        })
        if settings.DebugMode then
            print("[DEBUG] Macro data keys: " .. (function()
                local keys = {}
                for k in pairs(macroData or {}) do table.insert(keys, tostring(k)) end
                return table.concat(keys, ", ")
            end)())
        end
        return
    end

    local speed    = MacroState.MacroSpeed or 1
    local totalOps = #operations

    if not ReplicaSignal then
        WindUI:Notify({ Title = "Error", Content = "ReplicaSignal not found!", Duration = 3, Icon = "x-octagon" })
        return
    end

    if settings.DebugMode then
        print(string.format("[PLAY] Start: %s | %d ops | speed=%.2fx", MacroState.SelectedMacro or "?", totalOps, speed))
        for i, op in ipairs(operations) do
            print(string.format("  [%d] type=%s time=%.2f %s", i, op.type or "?", op.time or 0, 
                op.type == "place" and string.format("unit=%s slot=%s", tostring(op.unitName), tostring(op.slot)) or ""))
        end
    end

    WindUI:Notify({
        Title = "Macro Started",
        Content = string.format("%s | %d ops | %.2fx", MacroState.SelectedMacro or "?", totalOps, speed),
        Duration = 4, Icon = "play",
    })

    -- Reset tracking
    placeOrder     = 0
    orderToGameId  = {}
    gameIdToOrder  = {}
    gameIdToCFrame = {}
    gameIdToUnit   = {}

    local lastOpTime = 0

    for i, op in ipairs(operations) do
        if not MacroState.IsPlaying then
            WindUI:Notify({ Title = "Stopped", Content = "Playback stopped.", Duration = 2, Icon = "square" })
            return
        end

        -- รอจนถึงเวลาของ op นี้
        local waitTime = ((op.time or 0) - lastOpTime) / speed
        if waitTime > 0 then task.wait(waitTime) end
        lastOpTime = op.time or 0

        if not MacroState.IsPlaying then return end

        -- ตรวจสอบว่า GameState replica มีอยู่
        local gs = aeGameStateReplica()
        if not gs or not gs.Id then
            if settings.ShowPlaybackLog then
                WindUI:Notify({
                    Title = "Skip",
                    Content = "No GameState, op " .. i .. " skipped",
                    Duration = 1.2, Icon = "alert-triangle",
                })
            end
            continue
        end

        local stateId = tostring(gs.Id)

        -- ===== PLACE =====
        if op.type == "place" then
            local slot   = tonumber(op.slot) or 1
            local cfData = op.cframe or {0, 0, 0, 0}
            local x, y, z, yaw = cfData[1] or 0, cfData[2] or 0, cfData[3] or 0, cfData[4] or 0
            local cframe = CFrame.new(x, y, z) * CFrame.Angles(0, math.rad(yaw), 0)

            local ok, err = pcall(function()
                ReplicaSignal:FireServer(stateId, "PlaceGameUnit", slot, cframe)
            end)

            if settings.DebugMode then
                print(string.format("[PLAY] Op %d/%d PLACE slot=%d @ (%.1f,%.1f,%.1f) yaw=%.1f -> %s",
                    i, totalOps, slot, x, y, z, yaw, ok and "OK" or tostring(err)))
            end

            if settings.ShowPlaybackLog then
                WindUI:Notify({
                    Title = ok and "Placed" or "Place FAILED",
                    Content = string.format("[%d/%d] Slot %d @ (%.0f,%.0f) %s",
                        i, totalOps, slot, x, z, ok and "✓" or tostring(err)),
                    Duration = 1.2,
                    Icon = ok and "plus-circle" or "x-circle",
                })
            end

            -- track expected order (เพื่อให้ sell ใช้ได้)
            local order = op.order or (placeOrder + 1)
            placeOrder = math.max(placeOrder, order)

            task.wait(0.08) -- delay เล็กน้อยเพื่อให้ server ตอบกลับ

        -- ===== SELL =====
        elseif op.type == "sell" then
            local order = op.order
            local gid   = findGameIdByOrder(order)

            -- fallback: หา order จาก cframe
            if not gid and op.cframe then
                local matchedOrder = findOrderByCFrame(op.cframe)
                if matchedOrder then gid = findGameIdByOrder(matchedOrder) end
            end

            if gid then
                pcall(function() ReplicaSignal:FireServer(stateId, "SellGameUnit", gid) end)
                if settings.ShowPlaybackLog then
                    WindUI:Notify({
                        Title = "Sold",
                        Content = string.format("[%d/%d] Unit #%d", i, totalOps, order or 0),
                        Duration = 1.2, Icon = "minus-circle",
                    })
                end
            else
                if settings.ShowPlaybackLog then
                    WindUI:Notify({
                        Title = "Sell Skipped",
                        Content = "Unit not found for op " .. i,
                        Duration = 1.2, Icon = "x-circle",
                    })
                end
            end

        -- ===== UPGRADE =====
        elseif op.type == "upgrade" then
            if settings.ShowPlaybackLog then
                WindUI:Notify({
                    Title = "Upgrade (auto)",
                    Content = string.format("[%d/%d] Unit #%d -> Lv%s", i, totalOps, op.order or 0, tostring(op.level or "?")),
                    Duration = 1.2, Icon = "arrow-up-circle",
                })
            end
        end
    end

    WindUI:Notify({
        Title = "Macro Complete",
        Content = string.format("%s (%d ops) finished.", MacroState.SelectedMacro or "?", totalOps),
        Duration = 4, Icon = "check-circle",
    })
end

local function startPlayback()
    if MacroState.IsRecording then
        WindUI:Notify({ Title = "Error", Content = "Stop recording first!", Duration = 3, Icon = "alert-triangle" })
        return false
    end
    if not MacroState.SelectedMacro then
        WindUI:Notify({ Title = "Error", Content = "No macro selected! Pick one from 'Load Macro'.", Duration = 3, Icon = "alert-triangle" })
        return false
    end

    local data = loadMacroFromFile(MacroState.SelectedMacro)
    if not data then
        WindUI:Notify({ 
            Title = "Load Failed", 
            Content = "Cannot read: " .. MacroState.SelectedMacro, 
            Duration = 3, 
            Icon = "alert-triangle" 
        })
        return false
    end

    -- ★ DEBUG: แสดงจำนวน ops ที่โหลดได้
    local opCount = (data.operations and #data.operations) or (data.ops and #data.ops) or 0
    if settings.DebugMode then
        print(string.format("[DEBUG] Loaded macro '%s' with %d ops", MacroState.SelectedMacro, opCount))
    end
    if opCount == 0 then
        WindUI:Notify({ 
            Title = "Empty Macro", 
            Content = "This macro has 0 operations! Try recording again.", 
            Duration = 4, 
            Icon = "alert-triangle" 
        })
        return false
    end

    MacroState.CurrentMacro = data
    MacroState.IsPlaying = true
    updateStatus()

    MacroState.PlaybackThread = task.spawn(function()
        local ok, err = pcall(playbackMacro, data)
        if not ok then
            WindUI:Notify({ Title = "Playback Error", Content = tostring(err), Duration = 4, Icon = "x-octagon" })
            if settings.DebugMode then warn("[PLAY ERROR] " .. tostring(err)) end
        end
        MacroState.IsPlaying    = false
        MacroState.CurrentMacro = nil
        pcall(function() UI.playToggle:Set(false) end)
        updateStatus()
    end)
    return true
end

local function stopPlayback()
    if not MacroState.IsPlaying then return false end
    MacroState.IsPlaying = false
    WindUI:Notify({ Title = "Stopping", Content = "Will stop at next operation...", Duration = 2, Icon = "square" })
    return true
end

