-- No Tool Appear (แก้ไขให้ทำงานเหมือน CUT เดียวกัน)
MainTab:Toggle({
    Title    = "No Tool Appear",
    Desc     = "Automatically restore the selected Tool if it disappears (e.g. after death or drop)",
    Value    = settings.NoToolAppear,
    Callback = function(state)
        settings.NoToolAppear = state
        Config:Set("NoToolAppear", state)
        Config:Save()
        if state then
            noToolTM:Start(function()
                if not selectedToolString or selectedToolString == "" then return end
                local pn, tn = selectedToolString:match("^(.-) | (.*)$")
                if not pn or not tn then return end

                local mb = LocalPlayer:FindFirstChild("Backpack")
                if not mb then return end

                local has = false
                for _, it in pairs(mb:GetChildren()) do
                    if it:IsA("Tool") and it.Name == tn then has = true break end
                end
                if not has and LocalPlayer.Character then
                    for _, it in pairs(LocalPlayer.Character:GetChildren()) do
                        if it:IsA("Tool") and it.Name == tn then has = true break end
                    end
                end

                -- ถ้าเราไม่มี แต่ผู้เล่นต้นทางยังมี -> CUT มาใหม่
                if not has then
                    local tp = Players:FindFirstChild(pn)
                    if tp then
                        local st = nil
                        local b = tp:FindFirstChild("Backpack")
                        if b then
                            local found = b:FindFirstChild(tn)
                            if found and found:IsA("Tool") then st = found end
                        end
                        if not st and tp.Character then
                            local found = tp.Character:FindFirstChild(tn)
                            if found and found:IsA("Tool") then st = found end
                        end
                        if st and mb then
                            pcall(function()
                                local cloned = st:Clone()
                                st:Destroy()
                                cloned.Parent = mb
                            end)
                            WindUI:Notify({
                                Title = "Tool Restored",
                                Content = tn .. " has been restored to your inventory.",
                                Duration = 2,
                                Icon = "shield"
                            })
                        end
                    end
                end
            end)
        else
            noToolTM:Stop()
        end
    end
})

