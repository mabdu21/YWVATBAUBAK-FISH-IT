-- ============================================================
-- CORE TOOL GIVER FUNCTION (TRUE CUT / MOVE)
-- ============================================================
-- การทำงาน:
-- 1. หาต้นฉบับจาก Backpack/Character ของเป้าหมาย
-- 2. ลบของเดิมของเราที่ชื่อเหมือนกันทิ้ง (กัน Visual)
-- 3. Clone ต้นฉบับมาเข้า Backpack เรา
-- 4. ทำลายต้นฉบับทันที (CUT - ไม่เหลือต้นฉบับ)
-- หมายเหตุ: Roblox Client ไม่สามารถย้าย Instance ข้าม Player โดยตรง
-- การ Clone เป็นวิธีเดียวที่ทำได้ แต่เราทำลายต้นฉบับเสมอ = CUT จริง
-- ============================================================
local function giveTool()
    if not selectedToolString or selectedToolString == "" then
        WindUI:Notify({Title = "Error", Content = "Please select a Tool first.", Duration = 2, Icon = "alert-triangle"})
        return
    end

    local playerName, toolName = selectedToolString:match("^(.-) | (.*)$")
    if not playerName or not toolName then
        WindUI:Notify({Title = "Error", Content = "Invalid Tool format.", Duration = 2, Icon = "alert-triangle"})
        return
    end

    local targetPlayer = Players:FindFirstChild(playerName)
    if not targetPlayer then
        WindUI:Notify({Title = "Error", Content = "Player '" .. playerName .. "' not found.", Duration = 2, Icon = "alert-triangle"})
        return
    end

    -- ค้นหาต้นฉบับจาก Backpack ก่อน แล้วจึง Character
    local sourceTool = nil
    local sourceLocation = nil
    local backpack = targetPlayer:FindFirstChild("Backpack")
    if backpack then
        local found = backpack:FindFirstChild(toolName)
        if found and found:IsA("Tool") then
            sourceTool = found
            sourceLocation = "Backpack"
        end
    end
    if not sourceTool and targetPlayer.Character then
        local found = targetPlayer.Character:FindFirstChild(toolName)
        if found and found:IsA("Tool") then
            sourceTool = found
            sourceLocation = "Character"
        end
    end

    if not sourceTool then
        WindUI:Notify({Title = "Error", Content = "Tool '" .. toolName .. "' not found in " .. playerName .. "'s inventory.", Duration = 3, Icon = "alert-triangle"})
        return
    end

    local myBackpack = LocalPlayer:FindFirstChild("Backpack")
    if not myBackpack then
        WindUI:Notify({Title = "Error", Content = "Your Backpack could not be found.", Duration = 2, Icon = "alert-triangle"})
        return
    end

    -- ===== ขั้นตอนที่ 1: ลบของเก่าของเราที่ชื่อเหมือนกัน =====
    -- ป้องกัน Visual Duplication (กันไม่ให้มีของซ้ำ 2 อัน)
    for _, item in pairs(myBackpack:GetChildren()) do
        if item:IsA("Tool") and item.Name == toolName then
            pcall(function() item:Destroy() end)
        end
    end
    if LocalPlayer.Character then
        for _, item in pairs(LocalPlayer.Character:GetChildren()) do
            if item:IsA("Tool") and item.Name == toolName then
                pcall(function() item:Destroy() end)
            end
        end
    end

    -- ===== ขั้นตอนที่ 2: CUT - ทำลายต้นฉบับก่อน =====
    -- ทำลายต้นฉบับทันที เพื่อให้แน่ใจว่าไม่มีต้นฉบับเหลือ (CUT จริง ไม่ใช่ COPY)
    local sourceClone = nil
    pcall(function()
        -- เก็บ Reference ของ properties ก่อนทำลาย
        sourceClone = sourceTool:Clone()
        sourceTool:Destroy()
    end)

    if not sourceClone then
        WindUI:Notify({Title = "Error", Content = "Failed to retrieve the Tool.", Duration = 2, Icon = "alert-triangle"})
        return
    end

    -- ===== ขั้นตอนที่ 3: ย้าย Clone เข้า Backpack ของเรา =====
    local success, err = pcall(function()
        sourceClone.Parent = myBackpack
    end)

    if not success or not sourceClone or not sourceClone.Parent then
        WindUI:Notify({Title = "Error", Content = "Failed to transfer the Tool to your inventory.", Duration = 2, Icon = "alert-triangle"})
        return
    end

    WindUI:Notify({
        Title = "Success",
        Content = "Acquired " .. toolName .. " from " .. playerName .. " (Cut from " .. sourceLocation .. ").",
        Duration = 3,
        Icon = "check"
    })
end

