local ESPFolder = nil
pcall(function()
    local gui = Instance.new("ScreenGui")
    gui.Name = "DYHUB_ESP"
    gui.ResetOnSpawn = false
    gui.IgnoreGuiInset = true
    gui.DisplayOrder = 100
    local ok = pcall(function() return game:GetService("CoreGui") end)
    gui.Parent = (ok and game:GetService("CoreGui")) or LocalPlayer:WaitForChild("PlayerGui")
    ESPFolder = Instance.new("Folder")
    ESPFolder.Name = "ESP_Entities"
    ESPFolder.Parent = gui
end)

local ESPTracked = {}
local ESPData    = {}

local function getESPRoot(model)
    if not model then return nil end
    return model:FindFirstChild("HumanoidRootPart")
        or model:FindFirstChild("Head")
        or model.PrimaryPart
        or model:FindFirstChildWhichIsA("BasePart")
end

local function getEntityType(model)
    local plr = Players:GetPlayerFromCharacter(model)
    if plr then return "Player", plr end
    local hum = model and model:FindFirstChildWhichIsA("Humanoid")
    if hum and hum.WalkSpeed > 16 then return "Monster" end
    return "NPC"
end

local function getEntityColor(typ, plr)
    if typ == "Player" and plr and plr.Team and not plr.Neutral then
        return plr.TeamColor.Color
    end
    if typ == "Monster" then return Color3.fromRGB(255, 60, 60) end
    if typ == "NPC" then return Color3.fromRGB(255, 220, 60) end
    return Color3.fromRGB(70, 150, 255)
end

local function getSkeletonConnections(model)
    if model:FindFirstChild("UpperTorso") then
        return {
            {"Head", "UpperTorso"}, {"UpperTorso", "LowerTorso"},
            {"UpperTorso", "LeftUpperArm"}, {"LeftUpperArm", "LeftLowerArm"}, {"LeftLowerArm", "LeftHand"},
            {"UpperTorso", "RightUpperArm"}, {"RightUpperArm", "RightLowerArm"}, {"RightLowerArm", "RightHand"},
            {"LowerTorso", "LeftUpperLeg"}, {"LeftUpperLeg", "LeftLowerLeg"}, {"LeftLowerLeg", "LeftFoot"},
            {"LowerTorso", "RightUpperLeg"}, {"RightUpperLeg", "RightLowerLeg"}, {"RightLowerLeg", "RightFoot"},
        }
    end
    return {{"Head", "Torso"}, {"Torso", "Left Arm"}, {"Torso", "Right Arm"}, {"Torso", "Left Leg"}, {"Torso", "Right Leg"}}
end

local function getBoundingBox(model)
    local ok, cf, size = pcall(function() return model:GetBoundingBox() end)
    if ok and cf and size then return cf, size end
    return CFrame.new(model:GetModelCFrame().Position), Vector3.new(4, 6, 4)
end

local function createESPEntity(hum)
    if ESPData[hum] or not ESPFolder then return end
    local folder = Instance.new("Folder")
    folder.Name = "ESP_" .. hum:GetInstanceId()
    folder.Parent = ESPFolder
    ESPData[hum] = { Folder = folder, Lines = {} }
end

local function removeESPEntity(hum)
    local data = ESPData[hum]
    if not data then return end
    pcall(function() data.Folder:Destroy() end)
    ESPData[hum] = nil
end

local function clearAllESP()
    for hum in pairs(ESPData) do removeESPEntity(hum) end
end

local function buildLinePool(data, count, name)
    data.Lines[name] = data.Lines[name] or {}
    local pool = data.Lines[name]
    while #pool < count do
        local l = Instance.new("Frame")
        l.BackgroundColor3 = Color3.new(1, 1, 1)
        l.BorderSizePixel = 0
        l.Parent = data.Folder
        table.insert(pool, l)
    end
    return pool
end

local function trackHumanoid(hum)
    if not hum or not hum:IsA("Humanoid") then return end
    if ESPTracked[hum] then return end
    ESPTracked[hum] = true
    hum.Destroying:Connect(function()
        ESPTracked[hum] = nil
        removeESPEntity(hum)
    end)
    hum.Died:Connect(function() removeESPEntity(hum) end)
end

for _, obj in ipairs(Workspace:GetDescendants()) do
    if obj:IsA("Humanoid") then trackHumanoid(obj) end
end
Workspace.DescendantAdded:Connect(function(obj)
    if obj:IsA("Humanoid") then
        task.wait(0.05)
        trackHumanoid(obj)
    end
end)

espTM:Start(function()
    task.wait(ESPSettings.UpdateRate)
    if not ESPSettings.Enabled then clearAllESP(); return end

    local char = LocalPlayer.Character
    local myHRP = char and char:FindFirstChild("HumanoidRootPart")
    if not myHRP then clearAllESP(); return end

    local viewport = Camera.ViewportSize
    local maxRange = ESPSettings.Range or 500

    for hum in pairs(ESPTracked) do
        local model = hum.Parent
        if not model or not model.Parent or hum.Health <= 0 then
            ESPTracked[hum] = nil
            removeESPEntity(hum)
        else
            local typ, plr = getEntityType(model)
            if not ESPSettings.ShowYourself and model == LocalPlayer.Character then
                removeESPEntity(hum)
            elseif typ == "Player" and not ESPSettings.ShowPlayer then
                removeESPEntity(hum)
            elseif typ == "Monster" and not ESPSettings.ShowMonster then
                removeESPEntity(hum)
            elseif typ == "NPC" and not ESPSettings.ShowNPC then
                removeESPEntity(hum)
            else
                local root = getESPRoot(model)
                if root then
                    local dist = (myHRP.Position - root.Position).Magnitude
                    if dist <= maxRange then
                        createESPEntity(hum)
                        local data = ESPData[hum]
                        if not data then return end
                        local color = getEntityColor(typ, plr)
                        local folder = data.Folder

                        if ESPSettings.ShowHighlight then
                            if not data.Highlight or not data.Highlight.Parent then
                                data.Highlight = Instance.new("Highlight")
                                data.Highlight.Name = "Highlight"
                                data.Highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                                data.Highlight.FillTransparency = 0.72
                                data.Highlight.OutlineTransparency = 0
                                data.Highlight.Parent = folder
                            end
                            data.Highlight.Adornee = model
                            data.Highlight.FillColor = color
                            data.Highlight.OutlineColor = color
                        else
                            if data.Highlight then pcall(function() data.Highlight:Destroy() end); data.Highlight = nil end
                        end

                        if ESPSettings.ShowName or ESPSettings.ShowDistance then
                            if not data.Label or not data.Label.Parent then
                                local label = Instance.new("BillboardGui")
                                label.Name = "Label"
                                label.AlwaysOnTop = true
                                label.Size = UDim2.new(0, 160, 0, 28)
                                label.StudsOffset = Vector3.new(0, 3.2, 0)
                                label.Parent = folder
                                local text = Instance.new("TextLabel")
                                text.Name = "Text"
                                text.Size = UDim2.new(1, 0, 1, 0)
                                text.BackgroundTransparency = 1
                                text.TextColor3 = color
                                text.TextStrokeTransparency = 0.35
                                text.TextStrokeColor3 = Color3.new(0, 0, 0)
                                text.TextSize = 12
                                text.Font = Enum.Font.GothamSemibold
                                text.Text = ""
                                text.Parent = label
                                data.Label = label
                                data.Text  = text
                            end
                            data.Label.Adornee = root
                            local text = ""
                            if ESPSettings.ShowName then text = "[" .. model.Name .. " | HP: " .. math.floor(hum.Health) .. "]" end
                            if ESPSettings.ShowDistance then text = text .. " [" .. math.floor(dist) .. " studs]" end
                            if data.Text then
                                data.Text.Text = text
                                data.Text.TextColor3 = color
                            end
                        else
                            if data.Label then pcall(function() data.Label:Destroy() end); data.Label = nil; data.Text = nil end
                        end

                        if ESPSettings.ShowTracer then
                            local pool = buildLinePool(data, 1, "Tracer")
                            local sp, on = Camera:WorldToScreenPoint(root.Position)
                            local line = pool[1]
                            if on and sp.Z > 0 then
                                local startPos = Vector2.new(viewport.X / 2, viewport.Y)
                                local endPos   = Vector2.new(sp.X, sp.Y)
                                local delta = endPos - startPos
                                line.Visible = true
                                line.Size = UDim2.new(0, delta.Magnitude, 0, 1)
                                line.Position = UDim2.new(0, startPos.X, 0, startPos.Y)
                                line.Rotation = math.deg(math.atan2(delta.Y, delta.X))
                                line.AnchorPoint = Vector2.new(0, 0.5)
                                line.BackgroundColor3 = color
                                line.BorderSizePixel = 0
                            else
                                line.Visible = false
                            end
                        else
                            if data.Lines["Tracer"] then for _, l in ipairs(data.Lines["Tracer"]) do l.Visible = false end end
                        end

                        if ESPSettings.ShowBox3D then
                            local pool = buildLinePool(data, 12, "Box3D")
                            local cf, size = getBoundingBox(model)
                            local half = size / 2
                            local corners = {}
                            for x = -1, 1, 2 do for y = -1, 1, 2 do for z = -1, 1, 2 do
                                table.insert(corners, (cf * CFrame.new(half.X * x, half.Y * y, half.Z * z)).Position)
                            end end end
                            local edges = {{1,2},{2,4},{4,3},{3,1},{5,6},{6,8},{8,7},{7,5},{1,5},{2,6},{4,8},{3,7}}
                            for i, edge in ipairs(edges) do
                                local p1v, on1 = Camera:WorldToScreenPoint(corners[edge[1]])
                                local p2v, on2 = Camera:WorldToScreenPoint(corners[edge[2]])
                                local line = pool[i]
                                if on1 and on2 and p1v.Z > 0 and p2v.Z > 0 then
                                    local p1 = Vector2.new(p1v.X, p1v.Y)
                                    local p2 = Vector2.new(p2v.X, p2v.Y)
                                    local delta = p2 - p1
                                    line.Visible = true
                                    line.Size = UDim2.new(0, delta.Magnitude, 0, 1)
                                    line.Position = UDim2.new(0, p1.X, 0, p1.Y)
                                    line.Rotation = math.deg(math.atan2(delta.Y, delta.X))
                                    line.AnchorPoint = Vector2.new(0, 0.5)
                                    line.BackgroundColor3 = color
                                    line.BorderSizePixel = 0
                                else
                                    line.Visible = false
                                end
                            end
                        else
                            if data.Lines["Box3D"] then for _, l in ipairs(data.Lines["Box3D"]) do l.Visible = false end end
                        end

                        if ESPSettings.ShowSkeleton then
                            local conns = getSkeletonConnections(model)
                            local pool = buildLinePool(data, #conns, "Skeleton")
                            for i, c in ipairs(conns) do
                                local p1 = model:FindFirstChild(c[1])
                                local p2 = model:FindFirstChild(c[2])
                                local line = pool[i]
                                if p1 and p2 then
                                    local sp1, on1 = Camera:WorldToScreenPoint(p1.Position)
                                    local sp2, on2 = Camera:WorldToScreenPoint(p2.Position)
                                    if on1 and on2 and sp1.Z > 0 and sp2.Z > 0 then
                                        local v1 = Vector2.new(sp1.X, sp1.Y)
                                        local v2 = Vector2.new(sp2.X, sp2.Y)
                                        local delta = v2 - v1
                                        line.Visible = true
                                        line.Size = UDim2.new(0, delta.Magnitude, 0, 1)
                                        line.Position = UDim2.new(0, v1.X, 0, v1.Y)
                                        line.Rotation = math.deg(math.atan2(delta.Y, delta.X))
                                        line.AnchorPoint = Vector2.new(0, 0.5)
                                        line.BackgroundColor3 = color
                                        line.BorderSizePixel = 0
                                    else
                                        line.Visible = false
                                    end
                                else
                                    line.Visible = false
                                end
                            end
                        else
                            if data.Lines["Skeleton"] then for _, l in ipairs(data.Lines["Skeleton"]) do l.Visible = false end end
                        end
                    else
                        removeESPEntity(hum)
                    end
                else
                    removeESPEntity(hum)
                end
            end
        end
    end
end)

