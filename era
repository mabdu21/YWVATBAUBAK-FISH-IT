local ThreadManager = {}
ThreadManager.__index = ThreadManager

function ThreadManager.new()
    return setmetatable({ running = false, thread = nil }, ThreadManager)
end

function ThreadManager:Start(loopFn)
    self:Stop()
    self.running = true
    self.thread = task.spawn(function()
        while self.running do
            local ok, err = pcall(loopFn)
            if not ok then
                warn("[DYHUB] Thread error:", err)
                break
            end
            if not self.running then break end
            task.wait(0.05)
        end
        self.running = false
        self.thread = nil
    end)
end

function ThreadManager:Stop()
    self.running = false
    if self.thread then
        pcall(function() task.cancel(self.thread) end)
        self.thread = nil
    end
end

function ThreadManager:IsRunning()
    return self.running
end

