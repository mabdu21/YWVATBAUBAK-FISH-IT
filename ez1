-- ====================== CUSTOM CONFIG SYSTEM ======================
-- [IMPROVED] Added dirty-flag to prevent save spam
-- [IMPROVED] Added value validation on load
local ConfigFolder = "DYHUB_STBB"

local CustomConfig = {}
CustomConfig.__index = CustomConfig

function CustomConfig.new()
    local self = setmetatable({}, CustomConfig)
    self.ConfigData  = {}
    self.ConfigPath  = ConfigFolder .. "/config_update_001.json"
    self._dirty      = false
    self._lastSave   = 0
    self._saveMinInterval = 2 -- minimum seconds between saves
    if not isfolder(ConfigFolder) then makefolder(ConfigFolder) end
    self:Load()
    return self
end

function CustomConfig:Set(key, value)
    if self.ConfigData[key] ~= value then
        self.ConfigData[key] = value
        self._dirty = true
    end
end

function CustomConfig:Get(key, default)
    local v = self.ConfigData[key]
    if v ~= nil then return v end
    return default
end

function CustomConfig:Save()
    -- [IMPROVED] Prevent save spam with minimum interval
    local now = os.clock()
    if now - self._lastSave < self._saveMinInterval then return end
    self._lastSave = now
    self._dirty    = false
    local ok, err = pcall(function()
        writefile(self.ConfigPath, HttpService:JSONEncode(self.ConfigData))
    end)
    if not ok then warn("[DYHUB] Save failed:", err) end
end

function CustomConfig:ForceSave()
    self._lastSave = 0
    self:Save()
end

function CustomConfig:Load()
    if not isfile(self.ConfigPath) then
        print("[DYHUB] No config found, using defaults")
        self.ConfigData = {}
        return
    end
    local ok, result = pcall(function()
        return HttpService:JSONDecode(readfile(self.ConfigPath))
    end)
    if ok and type(result) == "table" then
        -- [IMPROVED] Validate: strip non-serializable values
        for k, v in pairs(result) do
            local t = type(v)
            if t ~= "number" and t ~= "string" and t ~= "boolean" and t ~= "table" then
                result[k] = nil
            end
        end
        self.ConfigData = result
        print("[DYHUB] Config loaded!")
    else
        warn("[DYHUB] Failed to load config, using defaults")
        self.ConfigData = {}
    end
end

function CustomConfig:AutoSave(interval)
    task.spawn(function()
        while true do
            task.wait(interval or 15)
            if self._dirty then self:Save() end
        end
    end)
end

