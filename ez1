-- ====================== MOB SELECTION ======================
local function GetNearestMob()
    local livingFolder = GetLivingFolder()
    if not livingFolder or not HumanoidRootPart then return nil end
    local nearest, nearDist = nil, math.huge
    local myPos = HumanoidRootPart.Position
    for _, mob in ipairs(livingFolder:GetChildren()) do
        if IsValidMob(mob) then
            local hrp = mob:FindFirstChild("HumanoidRootPart")
            if hrp then
                local d = (myPos - hrp.Position).Magnitude
                if d < nearDist then nearDist = d; nearest = mob end
            end
        end
    end
    return nearest
end

local function GetHelicopter()
    local livingFolder = GetLivingFolder()
    if not livingFolder then return nil end
    for _, mob in ipairs(livingFolder:GetChildren()) do
        if mob.Name:lower():find("helicopter") and IsValidMob(mob) then return mob end
    end
    return nil
end

local function GetGiantSTToilet()
    local livingFolder = GetLivingFolder()
    if not livingFolder then return nil, nil end
    local giant = livingFolder:FindFirstChild("Giant ST toilet")
    if giant and IsValidMob(giant) then
        local lever = giant:FindFirstChild("lever")
        if lever then
            local prompt = lever:FindFirstChildOfClass("ProximityPrompt")
            if prompt then return giant, prompt end
        end
    end
    return nil, nil
end

local function GetHighHPMob()
    local livingFolder = GetLivingFolder()
    if not livingFolder then return nil end
    local best, bestHP = nil, HighHPThreshold
    for _, mob in ipairs(livingFolder:GetChildren()) do
        if IsValidMob(mob) then
            local hp = GetMobMaxHP(mob)
            if hp > bestHP then bestHP = hp; best = mob end
        end
    end
    return best
end

