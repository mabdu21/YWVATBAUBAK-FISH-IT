        MobHeightOverride[mob] = ClampPaddingToAntiClip(mob, MobHeightOverride[mob] or HeightValue)

        local lastDmgTime = tick()
        local noDmgTimer  = 0
        local hitStreak   = 0
        local lastWasHit  = false
        local reducedOnce = false

        while mob and mob.Parent and not IsMobDead(mob) and AutoFarmEnabled do
            task.wait(0.3)
            if MobCheckerCancelled[mob] then break end
            hum = mob:FindFirstChild("Humanoid")
            if not hum then break end

            local curHP  = hum.Health
            local lastHP = MobLastHealth[mob] or curHP
            local dmg    = lastHP - curHP

            if dmg > 0 then
                lastDmgTime = tick(); noDmgTimer = 0; reducedOnce = false
                hitStreak   = lastWasHit and hitStreak + 1 or 1
                lastWasHit  = true
                local curPad = GetEffectivePadding(mob)
                if not MobCheckerCancelled[mob] then
                    if dmg >= DMG_THRESHOLD or hitStreak >= 2 then
                        MobConfirmedPadding[mob] = curPad
                        MobHeightOverride[mob]   = curPad
                        break
                    end
                end
            else
                lastWasHit  = false; hitStreak = 0
                noDmgTimer  = tick() - lastDmgTime
            end

            if noDmgTimer >= 3 and not reducedOnce then
                reducedOnce = true
                local np = ClampPaddingToAntiClip(mob, GetEffectivePadding(mob) - PADDING_REDUCE_STEP)
                if np ~= GetEffectivePadding(mob) then MobHeightOverride[mob] = np end
            end
            if noDmgTimer >= 6 then
                lastDmgTime = tick(); reducedOnce = false
                local np = ClampPaddingToAntiClip(mob, GetEffectivePadding(mob) - PADDING_REDUCE_STEP)
                if np ~= GetEffectivePadding(mob) then MobHeightOverride[mob] = np end
            end
            MobLastHealth[mob] = curHP
        end

        if not MobCheckerCancelled[mob] then
            MobHeightOverride[mob] = nil
            MobLastHealth[mob]     = nil
        end
    end)
end

local function ResetMobOverride(mob)
    MobCheckerCancelled[mob] = true
    MobHeightOverride[mob]   = nil
    MobConfirmedPadding[mob] = nil
    MobLastHealth[mob]       = nil
    task.delay(0.5, function() MobCheckerCancelled[mob] = nil end)
end

-- ====================== TARGET CFRAME ======================
local function GetTargetCFrame(mob, position)
    if not mob or not mob.Parent then return nil end
    local mobRoot = mob:FindFirstChild("HumanoidRootPart")
    if not mobRoot then return nil end
    local padding = GetEffectivePadding(mob)
    local center, minY, maxY = GetMobVisualBounds(mob)
    if position == "Above" then
        local sy  = math.max(maxY + padding, maxY + 0.5)
        local tp2 = Vector3.new(center.X, sy, center.Z)
        local lk  = Vector3.new(center.X, maxY, center.Z)
        return CFrame.new(tp2, lk) * CFrame.Angles(math.rad(-10), 0, 0)
    elseif position == "Under" then
        local sy  = math.min(minY - padding, minY - 0.5)
        local tp2 = Vector3.new(center.X, sy, center.Z)
        local lk  = Vector3.new(center.X, minY, center.Z)
        return CFrame.new(tp2, lk) * CFrame.Angles(math.rad(10), 0, 0)
    end
    return nil
end

