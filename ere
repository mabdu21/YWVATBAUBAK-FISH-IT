-- =====================================================================
-- ====================== ESP MODULE (Bottom) ==========================
-- =====================================================================
do
    local ESPColors = {
        PlayerHighlight  = Color3.fromRGB(70, 150, 255),
        PlayerText       = Color3.fromRGB(70, 150, 255),
        MonsterHighlight = Color3.fromRGB(255, 60, 60),
        MonsterText      = Color3.fromRGB(255, 90, 90),
        NPCHighlight     = Color3.fromRGB(255, 220, 60),
        NPCText          = Color3.fromRGB(255, 220, 60),
    }

    local Tracked = {}
    local ESPObjects = {}

    local function getGuiParent()
        local ok, core = pcall(function() return game:GetService("CoreGui") end)
        if ok and core then return core end
        return LocalPlayer:WaitForChild("PlayerGui")
    end

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "DYHUB_ESP_UI"
    ScreenGui.ResetOnSpawn = false
    ScreenGui.IgnoreGuiInset = true
    ScreenGui.Parent = getGuiParent()

    local ESPFolder = Instance.new("Folder")
    ESPFolder.Name = "ESP_Objects"
    ESPFolder.Parent = ScreenGui

    local function getCharacter()
        return LocalPlayer.Character
    end

    local function getRoot(model)
        return model:FindFirstChild("HumanoidRootPart")
            or model:FindFirstChild("Head")
            or model.PrimaryPart
            or model:FindFirstChildWhichIsA("BasePart")
    end

    local function getVisualData(model, hum)
        local plr = Players:GetPlayerFromCharacter(model)
        if plr then
            return "Player", ESPColors.PlayerHighlight, ESPColors.PlayerText
        elseif hum.WalkSpeed > 16 then
            return "Monster", ESPColors.MonsterHighlight, ESPColors.MonsterText
        else
            return "NPC", ESPColors.NPCHighlight, ESPColors.NPCText
        end
    end

    local function removeESP(hum)
        local data = ESPObjects[hum]
        if not data then return end
        if data.Highlight then pcall(function() data.Highlight:Destroy() end) end
        if data.Billboard then pcall(function() data.Billboard:Destroy() end) end
        ESPObjects[hum] = nil
    end

    local function createESP(model, hum)
        if ESPObjects[hum] then return end
        local root = getRoot(model)
        if not root then return end

        local _, highlightColor, textColor = getVisualData(model, hum)

        local ok1, highlight = pcall(function()
            local h = Instance.new("Highlight")
            h.Name = "DYHUB_ESP_Highlight"
            h.Adornee = model
            h.FillColor = highlightColor
            h.OutlineColor = highlightColor
            h.FillTransparency = 0.72
            h.OutlineTransparency = 0
            h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            h.Parent = ESPFolder
            return h
        end)
        if not ok1 then return end

        local ok2, billboard = pcall(function()
            local b = Instance.new("BillboardGui")
            b.Name = "DYHUB_ESP_Label"
            b.Adornee = root
            b.AlwaysOnTop = true
            b.Size = UDim2.new(0, 145, 0, 24)
            b.StudsOffset = Vector3.new(0, 3.2, 0)
            b.Parent = ESPFolder

            local text = Instance.new("TextLabel")
            text.Size = UDim2.new(1, 0, 1, 0)
            text.BackgroundTransparency = 1
            text.TextColor3 = textColor
            text.TextStrokeTransparency = 0.35
            text.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
            text.TextSize = 11
            text.Font = Enum.Font.GothamSemibold
            text.Text = "[ " .. model.Name .. " / HP: " .. math.floor(hum.Health) .. " ]"
            text.Parent = b
            return b
        end)
        if not ok2 then
            pcall(function() highlight:Destroy() end)
            return
        end

        ESPObjects[hum] = {
            Model = model,
            Humanoid = hum,
            Highlight = highlight,
            Billboard = billboard,
            Text = billboard:FindFirstChildWhichIsA("TextLabel"),
        }
    end

    local function updateESP(hum)
        local data = ESPObjects[hum]
        if not data then return end

        local model = hum.Parent
        local root = model and getRoot(model)

        if not model or not root or hum.Health <= 0 then
            removeESP(hum)
            return
        end

        local _, highlightColor, textColor = getVisualData(model, hum)

        pcall(function()
            data.Highlight.Adornee = model
            data.Highlight.FillColor = highlightColor
            data.Highlight.OutlineColor = highlightColor

            data.Billboard.Adornee = root
            if data.Text then
                data.Text.TextColor3 = textColor
                data.Text.Text = "[ " .. model.Name .. " / HP: " .. math.floor(hum.Health) .. " ]"
            end
        end)
    end

    local function trackHumanoid(hum)
        if not hum or not hum:IsA("Humanoid") then return end
        if Tracked[hum] then return end
        Tracked[hum] = true

        hum.Destroying:Connect(function()
            Tracked[hum] = nil
            removeESP(hum)
        end)

        hum.Died:Connect(function()
            removeESP(hum)
        end)
    end

    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Humanoid") then
            trackHumanoid(obj)
        end
    end

    Workspace.DescendantAdded:Connect(function(obj)
        if obj:IsA("Humanoid") then
            task.wait(0.05)
            trackHumanoid(obj)
        end
    end)

    local function clearAllESP()
        for hum in pairs(ESPObjects) do
            removeESP(hum)
        end
    end

    -- Main ESP loop
    task.spawn(function()
        while ScreenGui and ScreenGui.Parent do
            task.wait(ESPSettings.UpdateRate or 0.25)

            if not ESPSettings.ESPEnabled then
                clearAllESP()
                continue
            end

            local char = getCharacter()
            local myRoot = char and char:FindFirstChild("HumanoidRootPart")
            if not myRoot then
                clearAllESP()
                continue
            end

            local maxRange = ESPSettings.Range or 500

            for hum in pairs(Tracked) do
                local model = hum.Parent

                if not model or hum.Health <= 0 then
                    Tracked[hum] = nil
                    removeESP(hum)
                elseif not ESPSettings.IncludeLocalPlayer and model == char then
                    removeESP(hum)
                else
                    local root = getRoot(model)
                    if root then
                        local distance = (myRoot.Position - root.Position).Magnitude
                        if distance <= maxRange then
                            createESP(model, hum)
                            updateESP(hum)
                        else
                            removeESP(hum)
                        end
                    else
                        removeESP(hum)
                    end
                end
            end
        end
    end)
end

