local function giveTool()
    if not selectedToolString or selectedToolString == "" then
        WindUI:Notify({Title = "Error", Content = "กรุณาเลือก Tool ก่อน!", Duration = 2, Icon = "alert-triangle"})
        return
    end

    local playerName, toolName = selectedToolString:match("^(.-) | (.*)$")
    if not playerName or not toolName then
        WindUI:Notify({Title = "Error", Content = "รูปแบบ Tool ไม่ถูกต้อง!", Duration = 2, Icon = "alert-triangle"})
        return
    end

    local targetPlayer = Players:FindFirstChild(playerName)
    if not targetPlayer then
        WindUI:Notify({Title = "Error", Content = "ไม่พบผู้เล่น '" .. playerName .. "'!", Duration = 2, Icon = "alert-triangle"})
        return
    end

    local sourceTool = nil
    local backpack = targetPlayer:FindFirstChild("Backpack")
    if backpack then
        sourceTool = backpack:FindFirstChild(toolName)
    end
    if not sourceTool and targetPlayer.Character then
        sourceTool = targetPlayer.Character:FindFirstChild(toolName)
    end

    if not sourceTool then
        WindUI:Notify({Title = "Error", Content = "ไม่พบ '" .. toolName .. "' ในกระเป๋าของ " .. playerName, Duration = 3, Icon = "alert-triangle"})
        return
    end

    local myBackpack = LocalPlayer:FindFirstChild("Backpack")
    if not myBackpack then
        WindUI:Notify({Title = "Error", Content = "ไม่พบ Backpack ของคุณ!", Duration = 2, Icon = "alert-triangle"})
        return
    end

    -- ลบของเดิมที่ชื่อเหมือนกัน (กันซ้ำ)
    for _, item in pairs(myBackpack:GetChildren()) do
        if item:IsA("Tool") and item.Name == toolName then
            pcall(function() item:Destroy() end)
        end
    end

    -- Clone และย้าย (CUT ไม่ใช่ COPY)
    local ok, clonedTool = pcall(function()
        local c = sourceTool:Clone()
        c.Parent = myBackpack
        return c
    end)

    if not ok or not clonedTool then
        WindUI:Notify({Title = "Error", Content = "ไม่สามารถย้าย Tool ได้!", Duration = 2, Icon = "alert-triangle"})
        return
    end

    -- ตัดของเดิมออก (client-side)
    pcall(function()
        sourceTool.Parent = nil
    end)

    WindUI:Notify({
        Title = "Success",
        Content = "ได้รับ " .. toolName .. " จาก " .. playerName .. " (Cut)",
        Duration = 3,
        Icon = "check"
    })
end

