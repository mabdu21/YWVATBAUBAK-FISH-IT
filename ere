-- ====================== No Tool Appear ======================
local noToolThread = nil

local function startNoToolAppear()
    if noToolThread then task.cancel(noToolThread) end
    noToolThread = task.spawn(function()
        while settings.NoToolAppear do
            task.wait(1)
            if not selectedToolString or selectedToolString == "" then continue end

            local playerName, toolName = selectedToolString:match("^(.-) | (.*)$")
            if not playerName or not toolName then continue end

            local myBackpack = LocalPlayer:FindFirstChild("Backpack")
            if not myBackpack then continue end

            local hasTool = false
            for _, item in pairs(myBackpack:GetChildren()) do
                if item:IsA("Tool") and item.Name == toolName then
                    hasTool = true
                    break
                end
            end

            if not hasTool and Character then
                for _, item in pairs(Character:GetChildren()) do
                    if item:IsA("Tool") and item.Name == toolName then
                        hasTool = true
                        break
                    end
                end
            end

            if not hasTool then
                local targetPlayer = Players:FindFirstChild(playerName)
                if targetPlayer then
                    local sourceTool = nil
                    local bp = targetPlayer:FindFirstChild("Backpack")
                    if bp then sourceTool = bp:FindFirstChild(toolName) end
                    if not sourceTool and targetPlayer.Character then
                        sourceTool = targetPlayer.Character:FindFirstChild(toolName)
                    end

                    if sourceTool and myBackpack then
                        pcall(function()
                            local cloned = sourceTool:Clone()
                            cloned.Parent = myBackpack
                            sourceTool.Parent = nil
                        end)
                        WindUI:Notify({
                            Title = "Tool Restored",
                            Content = toolName .. " ถูกเรียกคืนแล้ว!",
                            Duration = 2,
                            Icon = "shield"
                        })
                    end
                end
            end
        end
    end)
end

local function stopNoToolAppear()
    if noToolThread then
        task.cancel(noToolThread)
        noToolThread = nil
    end
end

