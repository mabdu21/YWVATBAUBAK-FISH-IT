local macroState = {
    isRecording      = false,
    isPlaying        = false,
    currentRecording = {},  -- {seq, kind, slot, cf={X,Y,Z,yaw}, unitName, gameId, elapsed}
    recordStart      = 0,
    recordSeq        = 0,
    playThread       = nil,
    selectedMacro    = settings.LoadMacro or "-- none --",
    availableMacros  = {},
}

local function listMacroFiles()
    local list = { "-- none --" }
    pcall(function()
        if listfiles then
            for _, fp in ipairs(listfiles(MACRO_FOLDER)) do
                if fp:match("%.json$") then
                    local name = fp:match("([^/\\]+)%.json$")
                    if name then table.insert(list, name) end
                end
            end
        end
    end)
    -- sort newest first
    table.sort(list, function(a, b)
        if a == "-- none --" then return true end
        if b == "-- none --" then return false end
        return a > b
    end)
    macroState.availableMacros = list
    return list
end

local function sanitizeName(name)
    if not name then return nil end
    name = tostring(name):gsub("[^%w_%-]", "_")
    name = name:gsub("_+", "_")
    if name == "" or name:match("^_+$") then return nil end
    return name
end

local function getNextDefaultName()
    for i = 1, 999 do
        local candidate = string.format("DYHUB_MACRO_%d", i)
        if not isfile(MACRO_FOLDER .. "/" .. candidate .. ".json") then
            return candidate
        end
    end
    return "DYHUB_MACRO_1"
end

