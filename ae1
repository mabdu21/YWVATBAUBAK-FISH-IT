-- ============================================================
-- MACRO PLAYBACK (Fixed: use ReplicaSignal:FireServer directly)
-- ============================================================
local function findGameIdByOrder(order)
    return orderToGameId[order]
end

local function findOrderByCFrame(cframeData, tolerance)
    tolerance = tolerance or 3
    if not cframeData then return nil end
    local x, z = cframeData[1], cframeData[3]
    for order, gid in pairs(orderToGameId) do
        local cf = gameIdToCFrame[gid]
        if cf and typeof(cf) == "CFrame" then
            local p = cf.Position
            if math.abs(p.X - x) < tolerance and math.abs(p.Z - z) < tolerance then
                return order
            end
        end
    end
    return nil
end

local function playbackMacro(macroData)
    if not macroData or not macroData.operations or #macroData.operations == 0 then
        WindUI:Notify({ Title = "Error", Content = "No operations in macro!", Duration = 3, Icon = "alert-triangle" })
        return
    end

    local speed      = MacroState.MacroSpeed or 1
    local operations = macroData.operations
    local totalOps   = #operations

    if not ReplicaSignal then
        WindUI:Notify({ Title = "Error", Content = "ReplicaSignal not found! Cannot play.", Duration = 3, Icon = "x-octagon" })
        return
    end

    WindUI:Notify({
        Title = "Macro Started",
        Content = string.format("%s | %d ops | Speed: %.2fx", MacroState.SelectedMacro or "?", totalOps, speed),
        Duration = 4,
        Icon = "play",
    })

    -- Reset tracking for new placement session
    placeOrder     = 0
    orderToGameId  = {}
    gameIdToOrder  = {}
    gameIdToCFrame = {}
    gameIdToUnit   = {}

    local lastOpTime = 0

    for i, op in ipairs(operations) do
        if not MacroState.IsPlaying then
            WindUI:Notify({ Title = "Stopped", Content = "Macro playback stopped.", Duration = 2, Icon = "square" })
            return
        end

        local waitTime = (op.time - lastOpTime) / speed
        if waitTime > 0 then task.wait(waitTime) end
        lastOpTime = op.time

        if not MacroState.IsPlaying then return end

        -- Get current GameState replica (Id changes per session)
        local gs = aeGameStateReplica()
        if not gs or not gs.Id then
            if settings.ShowPlaybackLog then
                WindUI:Notify({
                    Title = "Warning",
                    Content = "No GameState replica! Op " .. i .. " skipped.",
                    Duration = 1.5,
                    Icon = "alert-triangle",
                })
            end
            continue
        end

        local stateId = tostring(gs.Id)

        if op.type == "place" then
            local slot   = tonumber(op.slot) or 1
            local cfData = op.cframe or {0, 0, 0, 0}
            local cframe = CFrame.new(cfData[1] or 0, cfData[2] or 0, cfData[3] or 0) 
                            * CFrame.Angles(0, math.rad(cfData[4] or 0), 0)

            local ok, err = pcall(function()
                ReplicaSignal:FireServer(stateId, "PlaceGameUnit", slot, cframe)
            end)

            if ok then
                local order = op.order or (placeOrder + 1)
                placeOrder = math.max(placeOrder, order)
            end

            if settings.ShowPlaybackLog then
                WindUI:Notify({
                    Title = ok and "Placed" or "Place Failed",
                    Content = string.format("[%d/%d] Slot %d @ (%.0f, %.0f) | %s",
                        i, totalOps, slot, cfData[1] or 0, cfData[3] or 0,
                        ok and "OK" or tostring(err)),
                    Duration = 1.2,
                    Icon = ok and "plus-circle" or "x-circle",
                })
            end

            task.wait(0.05) -- small delay between ops

        elseif op.type == "sell" then
            local order = op.order
            local gid = findGameIdByOrder(order)
            if not gid and op.cframe then
                local matchedOrder = findOrderByCFrame(op.cframe)
                if matchedOrder then gid = findGameIdByOrder(matchedOrder) end
            end

            if gid then
                pcall(function()
                    ReplicaSignal:FireServer(stateId, "SellGameUnit", gid)
                end)
                if settings.ShowPlaybackLog then
                    WindUI:Notify({
                        Title = "Sold",
                        Content = string.format("[%d/%d] Unit #%d", i, totalOps, order),
                        Duration = 1.2,
                        Icon = "minus-circle",
                    })
                end
            else
                if settings.ShowPlaybackLog then
                    WindUI:Notify({
                        Title = "Sell Skipped",
                        Content = "Unit not found for op " .. i,
                        Duration = 1.2,
                        Icon = "x-circle",
                    })
                end
            end

        elseif op.type == "upgrade" then
            -- Upgrade is auto-detected by server (no client signal needed)
            if settings.ShowPlaybackLog then
                WindUI:Notify({
                    Title = "Upgrade (auto)",
                    Content = string.format("[%d/%d] Unit #%d -> Lv%s", i, totalOps, op.order or 0, tostring(op.level or "?")),
                    Duration = 1.2,
                    Icon = "arrow-up-circle",
                })
            end
        end
    end

    WindUI:Notify({
        Title = "Macro Complete",
        Content = string.format("%s (%d ops) finished.", MacroState.SelectedMacro or "?", totalOps),
        Duration = 4,
        Icon = "check-circle",
    })
end

local function startPlayback()
    if MacroState.IsRecording then
        WindUI:Notify({ Title = "Error", Content = "Cannot play while recording!", Duration = 3, Icon = "alert-triangle" })
        return false
    end
    if not MacroState.SelectedMacro then
        WindUI:Notify({ Title = "Error", Content = "No macro selected! Load one from dropdown.", Duration = 3, Icon = "alert-triangle" })
        return false
    end

    local data = loadMacroFromFile(MacroState.SelectedMacro)
    if not data then
        WindUI:Notify({ Title = "Error", Content = "Failed to load: " .. MacroState.SelectedMacro, Duration = 3, Icon = "alert-triangle" })
        return false
    end

    MacroState.CurrentMacro = data
    MacroState.IsPlaying = true
    updateStatus()

    MacroState.PlaybackThread = task.spawn(function()
        local ok, err = pcall(playbackMacro, data)
        if not ok then
            WindUI:Notify({ Title = "Playback Error", Content = tostring(err), Duration = 4, Icon = "x-octagon" })
        end
        MacroState.IsPlaying = false
        MacroState.CurrentMacro = nil
        updateStatus()
    end)
    return true
end

local function stopPlayback()
    if not MacroState.IsPlaying then return false end
    MacroState.IsPlaying = false
    WindUI:Notify({ Title = "Stopping", Content = "Will stop at next operation...", Duration = 2, Icon = "square" })
    return true
end

