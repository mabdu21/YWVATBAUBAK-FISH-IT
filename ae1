local function startRecording()
    if macroState.isPlaying then
        WindUI:Notify({Title="Cannot Record",Content="Stop playing macro first!",Duration=2,Icon="alert-triangle"})
        -- reflect UI
        pcall(function() MainTab:SetToggleValue("Record Macro", false) end)
        return
    end
    macroState.isRecording = true
    macroState.currentRecording = {}
    macroState.recordSeq = 0
    macroState.recordStart = tick()
    AE.seenId = {}
    AE.pending = {}
    WindUI:Notify({Title="Recording",Content="Started. Place units now!",Duration=2,Icon="circle"})
    updateStatus("● Status: RECORDING (place units in game)", Color3.fromRGB(255, 80, 80))
end

local function stopRecording()
    if not macroState.isRecording then return end
    macroState.isRecording = false
    local n = #macroState.currentRecording
    WindUI:Notify({
        Title = "Recording Stopped",
        Content = n .. " operations recorded. Use 'Save Macro' to store to disk.",
        Duration = 3,
        Icon = "square",
    })
    updateStatus(
        string.format("● Status: IDLE - %d ops recorded (use Save Macro)", n),
        Color3.fromRGB(100, 200, 255)
    )
end

local dropdownLoadMacro
local function refreshDropdown()
    local list = listMacroFiles()
    pcall(function()
        if dropdownLoadMacro and dropdownLoadMacro.Refresh then
            dropdownLoadMacro:Refresh(list)
        elseif dropdownLoadMacro and dropdownLoadMacro.SetValues then
            dropdownLoadMacro:SetValues(list)
        end
    end)
    -- make sure current selection is valid
    local found = false
    for _, n in ipairs(list) do
        if n == macroState.selectedMacro then found = true; break end
    end
    if not found then
        macroState.selectedMacro = "-- none --"
    end
end

local function saveMacro(name)
    name = sanitizeName(name)
    if not name then name = getNextDefaultName() end

    if #macroState.currentRecording == 0 then
        WindUI:Notify({Title="Save Failed",Content="No recording to save. Toggle Record Macro and place units first.",Duration=3,Icon="alert-triangle"})
        return false
    end

    local path = MACRO_FOLDER .. "/" .. name .. ".json"
    local data = {
        name    = name,
        created = os.time(),
        ops     = macroState.currentRecording,
    }
    local ok, err = pcall(function()
        writefile(path, HttpService:JSONEncode(data))
    end)
    if ok then
        WindUI:Notify({Title="Saved",Content="Macro saved: "..name,Duration=2,Icon="save"})
        refreshDropdown()
        macroState.selectedMacro = name
        settings.LoadMacro = name
        Config:Set("LoadMacro", name); Config:Save()
        pcall(function()
            if dropdownLoadMacro and dropdownLoadMacro.Set then
                dropdownLoadMacro:Set(name)
            end
        end)
        return true
    else
        WindUI:Notify({Title="Save Failed",Content=tostring(err),Duration=3,Icon="alert-triangle"})
        return false
    end
end

local function loadMacroData(name)
    if not name or name == "-- none --" then return nil end
    local path = MACRO_FOLDER .. "/" .. name .. ".json"
    if not isfile(path) then return nil end
    local ok, content = pcall(function() return readfile(path) end)
    if not ok or not content then return nil end
    local ok2, data = pcall(function() return HttpService:JSONDecode(content) end)
    if not ok2 or type(data) ~= "table" then return nil end
    return data
end

local function deleteMacro(name)
    if not name or name == "-- none --" then
        WindUI:Notify({Title="No Selection",Content="Select a macro first.",Duration=2,Icon="alert-triangle"})
        return
    end
    local path = MACRO_FOLDER .. "/" .. name .. ".json"
    if isfile(path) then
        pcall(function() delfile(path) end)
        WindUI:Notify({Title="Deleted",Content="Deleted: "..name,Duration=2,Icon="trash"})
        macroState.selectedMacro = "-- none --"
        settings.LoadMacro = "-- none --"
        Config:Set("LoadMacro", "-- none --"); Config:Save()
        refreshDropdown()
        pcall(function()
            if dropdownLoadMacro and dropdownLoadMacro.Set then
                dropdownLoadMacro:Set("-- none --")
            end
        end)
    end
end

local function stopMacro()
    macroState.isPlaying = false
    if macroState.playThread then
        pcall(function() task.cancel(macroState.playThread) end)
        macroState.playThread = nil
    end
    updateStatus("● Status: IDLE", Color3.fromRGB(160, 160, 160))
    pcall(function() MainTab:SetToggleValue("Start Macro", false) end)
    settings.StartMacro = false
    Config:Set("StartMacro", false); Config:Save()
end

local function startMacro()
    local name = macroState.selectedMacro
    if not name or name == "-- none --" then
        WindUI:Notify({Title="No Macro",Content="Select a macro in 'Load Macro' first.",Duration=3,Icon="alert-triangle"})
        pcall(function() MainTab:SetToggleValue("Start Macro", false) end)
        settings.StartMacro = false
        Config:Set("StartMacro", false); Config:Save()
        return
    end

    local data = loadMacroData(name)
    if not data or not data.ops or #data.ops == 0 then
        WindUI:Notify({Title="Load Failed",Content="Macro empty or invalid.",Duration=3,Icon="alert-triangle"})
        pcall(function() MainTab:SetToggleValue("Start Macro", false) end)
        settings.StartMacro = false
        Config:Set("StartMacro", false); Config:Save()
        return
    end

    if not ReplicaSignal then
        WindUI:Notify({Title="No Remote",Content="ReplicaSignal not found.",Duration=3,Icon="alert-triangle"})
        pcall(function() MainTab:SetToggleValue("Start Macro", false) end)
        return
    end

    macroState.isPlaying = true
    updateStatus(
        string.format("● Status: PLAYING %s (%d ops)", name, #data.ops),
        Color3.fromRGB(100, 220, 120)
    )

    macroState.playThread = task.spawn(function()
        local startTick = tick()
        for i, op in ipairs(data.ops) do
            if not macroState.isPlaying then break end
            -- wait for scheduled time
            while macroState.isPlaying do
                local now = tick() - startTick
                if now >= (op.elapsed or 0) then break end
                task.wait(math.min(0.05, (op.elapsed or 0) - now))
            end
            if not macroState.isPlaying then break end

            if op.kind == "place" and op.slot and op.cf and ReplicaSignal then
                local gsId = getGameStateId()
                if not gsId then
                    -- try Hotbar replica id
                    gsId = getHotbarReplicaId()
                end
                if gsId and gsId ~= "" then
                    local cf = CFrame.new(op.cf.X, op.cf.Y, op.cf.Z) *
                              (op.cf.yaw and CFrame.Angles(0, op.cf.yaw, 0) or CFrame.new())
                    pcall(function()
                        ReplicaSignal:FireServer(gsId, "PlaceGameUnit", op.slot, cf)
                    end)
                end
            elseif op.kind == "upgrade" and op.gameId and ReplicaSignal then
                local gsId = getGameStateId() or getHotbarReplicaId()
                if gsId and gsId ~= "" then
                    pcall(function()
                        ReplicaSignal:FireServer(gsId, "UpgradeGameUnit", op.gameId)
                    end)
                end
            elseif op.kind == "sell" and op.gameId and ReplicaSignal then
                local gsId = getGameStateId() or getHotbarReplicaId()
                if gsId and gsId ~= "" then
                    pcall(function()
                        ReplicaSignal:FireServer(gsId, "SellGameUnit", op.gameId)
                    end)
                end
            end
        end

        macroState.isPlaying = false
        updateStatus("● Status: FINISHED", Color3.fromRGB(160, 160, 160))
        pcall(function() MainTab:SetToggleValue("Start Macro", false) end)
        settings.StartMacro = false
        Config:Set("StartMacro", false); Config:Save()
    end)
end

