-- ============================================================
-- TRACKER CALLBACKS
-- ============================================================
local function Tracker_OnPlace(unitName, gameId, cframe, extra)
    local order = placeOrder
    placeOrder = placeOrder + 1

    local gid = tostring(gameId)
    gameIdToOrder[gid]  = order
    orderToGameId[order] = gid
    if cframe then gameIdToCFrame[gid] = cframe end
    gameIdToUnit[gid] = unitName

    if MacroState.IsRecording then
        local cfArgs = {0, 0, 0, 0}
        if cframe and typeof(cframe) == "CFrame" then
            local _, yawRad = cframe:ToOrientation()
            cfArgs = {cframe.X, cframe.Y, cframe.Z, math.deg(yawRad)}
        end
        table.insert(MacroState.RecordOps, {
            type     = "place",
            time     = getElapsed(),
            unitName = unitName,
            slot     = extra and extra.slot or 1,
            cframe   = cfArgs,
            order    = order,
        })
    end

    return order
end

local function Tracker_OnUpgrade(gameId, level)
    if MacroState.IsRecording then
        local order = gameIdToOrder[tostring(gameId)]
        if order then
            table.insert(MacroState.RecordOps, {
                type  = "upgrade",
                time  = getElapsed(),
                order = order,
                level = level,
            })
        end
    end
end

local function Tracker_OnSell(gameId)
    if MacroState.IsRecording then
        local order = gameIdToOrder[tostring(gameId)]
        if order then
            table.insert(MacroState.RecordOps, {
                type  = "sell",
                time  = getElapsed(),
                order = order,
            })
        end
    end
end

local function Tracker_OnGameStart(mapId)
    startGameTimer(mapId)
    placeOrder     = 0
    orderToGameId  = {}
    gameIdToOrder  = {}
    gameIdToCFrame = {}
    gameIdToUnit   = {}
end

local function Tracker_OnGameEnd()
    isGameRunning   = false
    gameStartSession = nil
end

-- ============================================================
-- GAME STATE LISTENER
-- ============================================================
local AE_GAME_OVER_STATES = { Victory = true, Lose = true, Defeat = true }

local function aeApplyGameState(r)
    local d = r and r.Data
    if not d then return end
    pcall(function()
        local p = d.Parameters or {}
        gameSettings.mapId     = tostring(p.MapName or "Unknown")
        gameSettings.difficulty = tostring(p.Difficulty or "Unknown")
        gameSettings.gamemode  = tostring(p.Gamemode or "Story")
        gameSettings.actName   = tostring(p.ActName or "Act 1")
    end)

    local state = d.CurrentGameState
    if state == "InProgress" then
        if not isGameRunning then Tracker_OnGameStart(gameSettings.mapId) end
    elseif isGameRunning and AE_GAME_OVER_STATES[tostring(state)] then
        Tracker_OnGameEnd()
    end
end

-- ============================================================
-- REPLICA HOOKS
-- ============================================================
local AE = {
    pending  = {},
    seenId   = {},
    seenSpot = {},
    watched  = {},
    hooked   = false,
}

local function aeIsClone(d)
    if d.IsClone == true then return true end
    local realAsset = d.UnitData and d.UnitData.Asset
    local idAsset = aeAssetOf(d.UnitID)
    if type(realAsset) == "string" and type(idAsset) == "string" 
       and realAsset ~= idAsset and realAsset ~= idAsset .. "EVO" then
        return true
    end
    return false
end

local function aeHotbar()
    return aeFind("HotbarData", function(r) return r.Data.PlacementAllowed == true end)
end

local function aeSlotAsset(slot)
    local hb = aeHotbar()
    if not hb then return nil end
    local s = hb.Data.Slots and hb.Data.Slots[slot]
    return s and aeAssetOf(s.ID) or nil
end

local function aeSpotKey(name, cf)
    if not cf then return nil end
    local p = cf.Position
    return string.format("%s@%.1f,%.1f", tostring(name), p.X, p.Z)
end

local function aeWatchUpgrades(replica)
    if AE.watched[replica] then return end
    AE.watched[replica] = true
    local last = replica.Data and replica.Data.Upgrade or 0
    pcall(function()
        replica:OnChange(function()
            local d = replica.Data
            if not d then return end
            local now = d.Upgrade
            if now == last or type(now) ~= "number" then return end
            last = now
            local gid = tostring(d.ID)
            queueHookTask(function() Tracker_OnUpgrade(gid, now) end)
        end)
    end)
end

local function aeOnNewUnit(replica)
    local d = replica.Data
    if not d or d.Owner ~= LocalPlayer then return end
    if aeIsClone(d) then return end

    aeWatchUpgrades(replica)

    local gid = tostring(d.ID)
    if AE.seenId[gid] then return end

    local name = aeAssetOf(d.UnitID) or (d.UnitData and d.UnitData.Asset) or "Unknown"
    local key  = aeSpotKey(name, d.CFrame)

    local prevOrder = key and AE.seenSpot[key]
    if prevOrder then
        AE.seenId[gid] = true
        gameIdToOrder[gid]  = prevOrder
        orderToGameId[prevOrder] = gid
        if d.CFrame then gameIdToCFrame[gid] = d.CFrame end
        gameIdToUnit[gid] = name
        return
    end

    AE.seenId[gid] = true

    local slot
    for i, p in ipairs(AE.pending) do
        if p.unitName == name then
            slot = p.slot
            table.remove(AE.pending, i)
            break
        end
    end

    Tracker_OnPlace(name, gid, d.CFrame, { slot = slot })

    if key then AE.seenSpot[key] = gameIdToOrder[gid] or 0 end
end

-- ============================================================
-- SIGNAL HANDLER (PlaceGameUnit, SellGameUnit)
-- ============================================================
local function aeHandleSignal(args)
    local signalName = args[2]
    if type(signalName) ~= "string" then return end

    if signalName == "PlaceGameUnit" then
        local slot, cf = args[3], args[4]
        table.insert(AE.pending, {
            slot     = slot,
            cframe   = cf,
            unitName = aeSlotAsset(slot),
            t        = tick(),
        })
        for i = #AE.pending, 1, -1 do
            if tick() - AE.pending[i].t > 10 then
                table.remove(AE.pending, i)
            end
        end
    elseif signalName == "SellGameUnit" then
        Tracker_OnSell(tostring(args[3]))
    elseif signalName == "SellAllGameUnits" then
        for _, r in pairs(aeReplicas()) do
            if r.Token == "GameUnit" and r.Data and r.Data.Owner == LocalPlayer and not aeIsClone(r.Data) then
                Tracker_OnSell(tostring(r.Data.ID))
            end
        end
    end
end

-- ============================================================
-- ADAPTER INIT (use hookmetamethod for compatibility)
-- ============================================================
local function Adapter_Init()
    if not ReplicaClient or not ReplicaSignal then return end
    if AE.hooked then return end
    AE.hooked = true

    -- 1) Hook __namecall via hookmetamethod (more reliable than direct mt)
    pcall(function()
        local oldNamecall
        oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
            local method = getnamecallmethod()
            if self == ReplicaSignal and method == "FireServer" then
                local args = table.pack(...)
                queueHookTask(function() pcall(aeHandleSignal, args) end)
            end
            return oldNamecall(self, ...)
        end))
    end)

    -- 2) Replica listeners
    pcall(function()
        ReplicaClient.OnNew("GameUnit", function(r)
            queueHookTask(function() aeOnNewUnit(r) end)
        end)
        ReplicaClient.OnNew("GamePhantom", function(r)
            queueHookTask(function() aeOnNewUnit(r) end)
        end)
        ReplicaClient.OnNew("GameState", function(r)
            queueHookTask(function() aeApplyGameState(r) end)
            pcall(function()
                r:OnChange(function()
                    queueHookTask(function() aeApplyGameState(r) end)
                end)
            end)
        end)
    end)

    -- 3) Backfill existing towers
    pcall(function()
        local mine = {}
        for _, r in pairs(aeReplicas()) do
            if (r.Token == "GameUnit" or r.Token == "GamePhantom") 
               and r.Data and r.Data.Owner == LocalPlayer and not aeIsClone(r.Data) then
                table.insert(mine, r)
            end
        end
        if #mine > 0 then
            table.sort(mine, function(a, b)
                return (tonumber(a.Data.PlacedAt) or 0) < (tonumber(b.Data.PlacedAt) or 0)
            end)
            local first = tonumber(mine[1].Data.PlacedAt)
            if first then
                gameStartSession = first
                isGameRunning = true
            end
            for _, r in ipairs(mine) do aeOnNewUnit(r) end
        end
    end)
end

-- ============================================================
-- MACRO FILE OPERATIONS
-- ============================================================
local function listMacros()
    local macros = {}
    pcall(function()
        if listfiles then
            for _, fp in ipairs(listfiles(MacroFolder)) do
                if fp:match("%.json$") then
                    local name = fp:match("([^/\\]+)%.json$")
                    if name then table.insert(macros, name) end
                end
            end
        end
    end)
    table.sort(macros, function(a, b) return a < b end)
    return macros
end

local function getNextAutoName()
    local existing = listMacros()
    local maxNum = 0
    for _, n in ipairs(existing) do
        local num = n:match("^DYHUB_MACRO_(%d+)$")
        if num then
            local v = tonumber(num)
            if v and v > maxNum then maxNum = v end
        end
    end
    return string.format("DYHUB_MACRO_%d", maxNum + 1)
end

local function ensureUniqueName(name)
    local existing = listMacros()
    if not table.find(existing, name) then return name end
    local base = name
    local counter = 1
    while table.find(existing, name) do
        name = base .. "_" .. counter
        counter = counter + 1
        if counter > 999 then break end
    end
    return name
end

local function saveMacroToFile(name, data)
    local safeName = name:gsub("[^%w_%-]", "_")
    if safeName == "" or safeName:match("^_+$") then
        return false, "Invalid name"
    end
    local path = MacroFolder .. "/" .. safeName .. ".json"
    local ok, err = pcall(function()
        writefile(path, HttpService:JSONEncode(data))
    end)
    return ok, err
end

local function loadMacroFromFile(name)
    local safeName = name:gsub("[^%w_%-]", "_")
    local path = MacroFolder .. "/" .. safeName .. ".json"
    if not isfile(path) then return nil end
    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(path))
    end)
    if ok and type(data) == "table" then return data end
    return nil
end

local function deleteMacroFile(name)
    local safeName = name:gsub("[^%w_%-]", "_")
    local path = MacroFolder .. "/" .. safeName .. ".json"
    pcall(function() delfile(path) end)
end

