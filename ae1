local function getInputValue(input)
    if not input then return "" end
    if type(input.Get) == "function" then
        local ok, v = pcall(function() return input:Get() end)
        if ok and v ~= nil then return tostring(v) end
    end
    if input.Value ~= nil then return tostring(input.Value) end
    return ""
end

