local Shared = ReplicatedStorage:FindFirstChild("Shared")
local function aeRequire(inst)
    if not inst then return nil end
    local prev = getthreadidentity and getthreadidentity() or nil
    if setthreadidentity then setthreadidentity(2) end
    local ok, mod = pcall(require, inst)
    if setthreadidentity and prev then setthreadidentity(prev) end
    if not ok then return nil end
    return mod
end

local ReplicaClient = Shared and aeRequire(Shared:FindFirstChild("ReplicaClient"))
local ReplicaSignal = (function()
    local re = ReplicatedStorage:FindFirstChild("RemoteEvents")
    return re and re:FindFirstChild("ReplicaSignal")
end)()

local function aeReplicas()
    if not ReplicaClient then return {} end
    local ok, t = pcall(function() return ReplicaClient.Test().Replicas end)
    return (ok and type(t) == "table") and t or {}
end
local function aeFind(token, pred)
    for _, r in pairs(aeReplicas()) do
        if r.Token == token and r.Data and (not pred or pred(r)) then
            return r
        end
    end
    return nil
end
local function aeHotbar()
    return aeFind("HotbarData", function(r) return r.Data.PlacementAllowed == true end)
end
local function aeAssetOf(unitID)
    return unitID and tostring(unitID):match("^([^#]+)") or nil
end
local function aeUnitName(replica)
    local d = replica.Data
    if not d then return "Unknown" end
    if type(d.UnitID) == "string" then
        local n = d.UnitID:match("^([^#]+)")
        if n then return n end
    end
    return (d.UnitData and d.UnitData.Asset) or "Unknown"
end
local function aeSlotAsset(slot)
    local hb = aeHotbar()
    if not hb then return nil end
    local s = hb.Data.Slots and hb.Data.Slots[slot]
    return s and aeAssetOf(s.ID) or nil
end
local function getGameStateReplica()
    return aeFind("GameState")
end
local function getGameStateId()
    local gs = getGameStateReplica()
    if not gs then return nil end
    return tostring(gs.Id or gs.ReplicaId or gs.replicaId or "")
end
local function getHotbarReplicaId()
    local hb = aeHotbar()
    if not hb then return nil end
    return tostring(hb.Id or hb.ReplicaId or hb.replicaId or "")
end

