-- ============================================================
--  Recording Hook
-- ============================================================
local AE = {
    pending = {},       -- pending PlaceGameUnit events waiting for replica
    seenId  = {},       -- replica-id -> true, avoid duplicates
    hooked  = false,
    playPendingPlace = {}, -- queue of place ops during play
}

local function addRecordingOp(kind, opts)
    if not macroState.isRecording then return end
    macroState.recordSeq = macroState.recordSeq + 1
    local elapsed = tick() - macroState.recordStart
    local op = {
        seq      = macroState.recordSeq,
        kind     = kind,
        elapsed  = elapsed,
    }
    if opts then
        for k, v in pairs(opts) do op[k] = v end
    end
    table.insert(macroState.currentRecording, op)
end

local function cfToXYZYaw(cf)
    local x, y, z = cf.X, cf.Y, cf.Z
    local _, yaw = cf:ToOrientation()
    return x, y, z, yaw
end

local function aeOnNewUnit(replica)
    local d = replica.Data
    if not d or d.Owner ~= LocalPlayer then return end
    if d.IsClone == true then return end
    local gid = tostring(d.ID)
    if AE.seenId[gid] then return end
    AE.seenId[gid] = true

    local name = aeUnitName(replica)
    local slot
    for i, p in ipairs(AE.pending) do
        if p.unitName == name then
            slot = p.slot
            table.remove(AE.pending, i)
            break
        end
    end

    if macroState.isRecording then
        local x, y, z, yaw = cfToXYZYaw(d.CFrame)
        addRecordingOp("place", {
            slot     = slot,
            unitName = name,
            gameId   = gid,
            cf       = { X = x, Y = y, Z = z, yaw = yaw },
        })
    end
end

local function aeHandleSignal(args)
    local signalName = args[2]
    if type(signalName) ~= "string" then return end

    if signalName == "PlaceGameUnit" then
        local slot, cf = args[3], args[4]
        table.insert(AE.pending, {
            slot     = slot,
            cframe   = cf,
            unitName = aeSlotAsset(slot),
            t        = tick(),
        })
        -- cleanup stale
        for i = #AE.pending, 1, -1 do
            if tick() - AE.pending[i].t > 10 then
                table.remove(AE.pending, i)
            end
        end
    elseif signalName == "UpgradeGameUnit" then
        if macroState.isRecording then
            addRecordingOp("upgrade", { gameId = tostring(args[3]) })
        end
    elseif signalName == "SellGameUnit" then
        if macroState.isRecording then
            addRecordingOp("sell", { gameId = tostring(args[3]) })
        end
    end
end

local function initAdapter()
    if not ReplicaClient or not ReplicaSignal then
        WindUI:Notify({
            Title = "Adapter",
            Content = "ReplicaClient / ReplicaSignal not found. Script will not record or play.",
            Duration = 5,
            Icon = "alert-triangle",
        })
        return
    end
    if AE.hooked then return end
    AE.hooked = true

    pcall(function()
        ReplicaClient.OnNew("GameUnit", function(r)
            task.defer(function() pcall(aeOnNewUnit, r) end)
        end)
        ReplicaClient.OnNew("GamePhantom", function(r)
            task.defer(function() pcall(aeOnNewUnit, r) end)
        end)
    end)

    pcall(function()
        local mt = getrawmetatable(game)
        local old = mt.__namecall
        setreadonly(mt, false)
        mt.__namecall = newcclosure(function(self, ...)
            if self == ReplicaSignal and getnamecallmethod() == "FireServer" then
                local args = table.pack(...)
                task.defer(function() pcall(aeHandleSignal, args) end)
            end
            return old(self, ...)
        end)
        setreadonly(mt, true)
    end)

    WindUI:Notify({
        Title = "Adapter",
        Content = "Anime Expedition adapter initialized.",
        Duration = 2,
        Icon = "check",
    })
end

