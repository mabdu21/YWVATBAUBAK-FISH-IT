    local macros = listMacros()
    local values = { "-- none --" }
    
    for _, macro in ipairs(macros) do
        table.insert(values, macro)
    end
    
    -- Debug info
    print("[DYHUB_AE] Found " .. #macros .. " macros")
    for i, m in ipairs(macros) do
        print("  [" .. i .. "] " .. m)
    end
    
    -- Update dropdown with new values
    pcall(function()
        loadMacroDropdown:Refresh(values)
    end)
end

