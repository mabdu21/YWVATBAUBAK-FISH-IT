-- ====================== MACRO COUNTER FUNCTIONS ======================
local function getNextMacroNumber()
    local count = MacroCounter:Get("count", 0)
    count = count + 1
    MacroCounter:Set("count", count)
    MacroCounter:Save()
    return count
end

local function generateMacroName()
    return "DYHUB_MACRO_" .. getNextMacroNumber()
end

-- ====================== MACRO FILE FUNCTIONS ======================
local function getMacroFileName(name)
    return MACRO_FOLDER .. "/" .. tostring(name) .. ".json"
end

local function saveMacro(name, actions)
    if not name or name == "" then
        WindUI:Notify({Title="Error",Content="Macro name cannot be empty!",Duration=2,Icon="alert-triangle"})
        return false
    end
    
    local data = {
        name = tostring(name),
        version = 1,
        createdAt = os.date("%Y-%m-%d %H:%M:%S"),
        actions = actions or {}
    }
    
    local filepath = getMacroFileName(name)
    
    local ok, err = pcall(function()
        local jsonStr = HttpService:JSONEncode(data)
        if not jsonStr then
            error("Failed to encode JSON")
        end
        if not writefile then
            error("writefile function not available")
        end
        writefile(filepath, jsonStr)
    end)
    
    if ok then
        WindUI:Notify({Title="Macro Saved",Content="Saved: " .. name,Duration=2,Icon="save"})
        task.wait(0.3)
        return true
    else
        WindUI:Notify({Title="Save Failed",Content="Error: " .. tostring(err),Duration=3,Icon="alert-triangle"})
        warn("[DYHUB_AE] Save error:", err)
        return false
    end
end

local function loadMacro(name)
    local path = getMacroFileName(name)
    if not isfile(path) then
        WindUI:Notify({Title="Error",Content="Macro not found: " .. name,Duration=2,Icon="ban"})
        return nil
    end
    
    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(path))
    end)
    
    if ok and data then
        return data.actions or {}
    else
        WindUI:Notify({Title="Error",Content="Failed to load macro",Duration=2,Icon="alert-triangle"})
        return nil
    end
end

local function listMacros()
    local macros = {}
    
    if not isfolder(MACRO_FOLDER) then
        return macros
    end
    
    local ok, result = pcall(function()
        if listfiles then
            return listfiles(MACRO_FOLDER)
        end
        return {}
    end)
    
    if ok and result then
        for _, filepath in ipairs(result) do
            if type(filepath) == "string" then
                local name = filepath:match("([^/\\]+)%.json$")
                if name and name ~= "macro_count.json" then
                    table.insert(macros, name)
                end
            end
        end
    end
    
    table.sort(macros, function(a, b)
        return a:lower() < b:lower()
    end)
    return macros
end

local function deleteMacro(name)
    local path = getMacroFileName(name)
    pcall(function()
        if delfile then
            delfile(path)
            WindUI:Notify({Title="Deleted",Content="Macro deleted: " .. name,Duration=2,Icon="trash-2"})
        end
    end)
end

-- ====================== ACTION RECORDING ======================
local function recordAction(actionType, data)
    if not MacroSystem.isRecording then return end
    
    local elapsed = tick() - MacroSystem.recordStartTime
    table.insert(MacroSystem.recordedActions, {
        type = actionType,
        elapsed = elapsed,
        data = data
    })
end

-- Hook for place unit detection - optimized version
local function setupRecordingHook()
    local ReplicaSignal = nil
    
    -- Wait for ReplicaSignal to load
    for i = 1, 10 do
        ReplicaSignal = ReplicatedStorage:FindFirstChild("RemoteEvents") and 
                       ReplicatedStorage.RemoteEvents:FindFirstChild("ReplicaSignal")
        if ReplicaSignal then break end
        task.wait(0.5)
    end
    
    if not ReplicaSignal then 
        warn("[DYHUB_AE] ReplicaSignal not found - macro recording disabled")
        return 
    end
    
    pcall(function()
        local mt = getrawmetatable(game)
        local oldNamecall = mt.__namecall
        setreadonly(mt, false)
        
        mt.__namecall = newcclosure(function(self, ...)
            if self == ReplicaSignal and getnamecallmethod() == "FireServer" then
                local args = table.pack(...)
                if args[2] == "PlaceGameUnit" and MacroSystem.isRecording then
                    local slot = args[3]
                    local cf = args[4]
                    if slot and cf then
                        recordAction("PlaceGameUnit", {
                            slot = slot,
                            position = {cf.X, cf.Y, cf.Z},
                            rotation = {cf:ToOrientation()}
                        })
                    end
                end
            end
            return oldNamecall(self, ...)
        end)
        
        setreadonly(mt, true)
    end)
end

-- ====================== ACTION PLAYBACK ======================
local function executeAction(action)
    if action.type == "PlaceGameUnit" then
        -- Find ReplicaSignal remote
        local ReplicaSignal = nil
        for i = 1, 5 do
            ReplicaSignal = ReplicatedStorage:FindFirstChild("RemoteEvents") and 
                           ReplicatedStorage.RemoteEvents:FindFirstChild("ReplicaSignal")
            if ReplicaSignal then break end
            task.wait(0.1)
        end
        
        if not ReplicaSignal then 
            warn("[DYHUB_AE] ReplicaSignal not found during playback")
            return false 
        end
        
        local data = action.data
        if not data then return false end
        
        local pos = data.position
        local rot = data.rotation
        
        if not pos or not rot then return false end
        
        -- Reconstruct CFrame
        local cf = CFrame.new(pos[1], pos[2], pos[3]) * CFrame.Angles(rot[1], rot[2], rot[3])
        
        -- Execute action safely
        local ok = pcall(function()
            if data.slot then
                ReplicaSignal:FireServer(0, "PlaceGameUnit", data.slot, cf)
            end
        end)
        
        if not ok then
            warn("[DYHUB_AE] Failed to execute PlaceGameUnit action")
        end
        
        return ok
    end
    return false
end

local playbackConnection = nil

local function startPlayback()
    if not MacroSystem.isPlaying or not MacroSystem.currentMacro then return end
    
    MacroSystem.playIndex = 1
    MacroSystem.playStartTime = tick()
    
    if playbackConnection then
        playbackConnection:Disconnect()
    end
    
    playbackConnection = RunService.Heartbeat:Connect(function()
        if not MacroSystem.isPlaying or not MacroSystem.currentMacro then
            if playbackConnection then
                playbackConnection:Disconnect()
                playbackConnection = nil
            end
            return
        end
        
        local elapsedSinceStart = tick() - MacroSystem.playStartTime
        
        while MacroSystem.playIndex <= #MacroSystem.currentMacro do
            local action = MacroSystem.currentMacro[MacroSystem.playIndex]
            if elapsedSinceStart >= action.elapsed then
                executeAction(action)
                MacroSystem.playIndex = MacroSystem.playIndex + 1
            else
                break
            end
        end
        
        if MacroSystem.playIndex > #MacroSystem.currentMacro then
            MacroSystem.isPlaying = false
            if playbackConnection then
                playbackConnection:Disconnect()
                playbackConnection = nil
            end
            WindUI:Notify({Title="Playback Complete",Content="Macro finished!",Duration=2,Icon="check"})
        end
    end)
end

