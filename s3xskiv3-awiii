local function startFollowCart()
    if Thread.cartFollow then
        pcall(function() task.cancel(Thread.cartFollow) end)
        Thread.cartFollow = nil
    end
    Thread.cartFollow = task.spawn(function()
        local lastATick = 0
        local RANGE     = 150
        while State.isFollowingCart do
            local cartRoot = findEscortCart()
            if cartRoot then
                local char = player.Character
                local hrp  = char and char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local cartPos = cartRoot.Position
                    local nearest, nearestD = nil, math.huge
                    local wf = WS:FindFirstChild("World") and WS.World:FindFirstChild("Enemies")
                    if wf then
                        for _, e in ipairs(wf:GetChildren()) do
                            if not isEnemyAlive(e) then continue end
                            local cf = getEnemyCFrame(e)
                            if cf then
                                local d = (cf.Position - cartPos).Magnitude
                                if d <= RANGE and d < nearestD then nearestD=d nearest=e end
                            end
                        end
                    end
                    if nearest then
                        local eCF = getEnemyCFrame(nearest)
                        if eCF then
                            hrp.CFrame = eCF * CFrame.new(0,3,0)
                            hrp.AssemblyLinearVelocity  = Vector3.zero
                            hrp.AssemblyAngularVelocity = Vector3.zero
                        end
                        if tick()-lastATick >= 0.2 then
                            lastATick = tick()
                            local units = getMyUnits()
                            local cf2 = getEnemyCFrame(nearest)
                            if cf2 then
                                teleportUnitsTo(cf2)
                                pcall(function() Remote.SendUnit:FireServer(nearest.Name, units) end)
                            end
                        end
                    else
                        hrp.CFrame = CFrame.new(cartPos + Vector3.new(0,20,0))
                        hrp.AssemblyLinearVelocity  = Vector3.zero
                        hrp.AssemblyAngularVelocity = Vector3.zero
                    end
                end
            else
                task.wait(2)
            end
            task.wait(0.1)
        end
    end)
