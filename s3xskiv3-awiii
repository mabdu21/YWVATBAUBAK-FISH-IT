Tab.Quest:Toggle({
    Title    = "Auto Quest",
    Icon     = "check-square",
    Type     = "Checkbox",
    Value    = Options.AutoQuest or false,
    Callback = function(v)
        State.isAutoQuest = v Options.AutoQuest = v SaveConfig()
        if v then
            task.spawn(function()
                while State.isAutoQuest do
                    if State.selectedQuestId=="" or State.selectedQuestId=="(No quests found)" then task.wait(1) continue end
                    local questId, _, tasks = getQuestInfoFromLabel(State.selectedQuestId)
                    if not questId then task.wait(1) continue end
                    WindUI:Notify({Title="Auto Quest",
                        Content=string.format("Starting: %s (%d tasks)", State.selectedQuestId, #tasks), Duration=4})
                    local allDone = true
                    for ti, taskInfo in ipairs(tasks) do
                        if not State.isAutoQuest then allDone=false break end
                        local enem     = taskInfo.enemy
                        local required = taskInfo.required
                        local kills    = 0
                        WindUI:Notify({Title=string.format("Task %d/%d",ti,#tasks),
                            Content=string.format("Target: [%s]  Need: %d", enem, required), Duration=4})
                        while State.isAutoQuest and kills < required do
                            local target = getTargetEnemy(enem)
                            if not target then task.wait(0.5) continue end
                            local char  = player.Character
                            local hrp   = char and char:FindFirstChild("HumanoidRootPart")
                            local units = getMyUnits()
                            local tPos  = getEnemyCFrame(target)
                            if tPos then
                                if hrp then hrp.CFrame = tPos * CFrame.new(0,5,0) hrp.AssemblyLinearVelocity = Vector3.zero end
                                teleportUnitsTo(tPos)
                                pcall(function() Remote.SendUnit:FireServer(target.Name, units) end)
                            end
                            while State.isAutoQuest and target and target.Parent do
                                if target:GetAttribute("dead") == true then
                                    kills += 1
                                    WindUI:Notify({Title=string.format("Kill %d/%d",kills,required),
                                        Content=string.format("[%s] Killed!",enem), Duration=2})
                                    break
                                end
                                local cur = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                                if cur then
                                    local cp = getEnemyCFrame(target)
                                    if cp and (cur.Position-cp.Position).Magnitude > 8 then
                                        cur.CFrame = cp * CFrame.new(0,5,0)
                                        cur.AssemblyLinearVelocity = Vector3.zero
                                        teleportUnitsTo(cp)
                                        pcall(function() Remote.SendUnit:FireServer(target.Name, getMyUnits()) end)
                                    end
                                end
                                task.wait(0.2)
                            end
                        end
                        WindUI:Notify({Title=string.format("Task %d/%d Done",ti,#tasks),
                            Content=string.format("[%s] x%d Complete!",enem,required), Duration=3})
                    end
                    if State.isAutoQuest and allDone then
                        WindUI:Notify({Title="Going to NPC",
                            Content=string.format("Claiming [%s]...", State.selectedQuestId), Duration=3})
                        task.wait(0.5)
                        goToNPCAndClaim(questId)
                        WindUI:Notify({Title="Reward Claimed!",
                            Content=string.format("[%s] collected!", State.selectedQuestId), Duration=4})
                    end
                    task.wait(2)
                end
            end)
        end
    end
})

