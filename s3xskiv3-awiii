Tab.Summon:Toggle({
    Title    = "Auto Open Egg",
    Icon     = "package",
    Type     = "Checkbox",
    Value    = Options.AutoEgg or false,
    Callback = function(v)
        State.isAutoEgg = v Options.AutoEgg = v SaveConfig()
        if State.isAutoEgg then
            task.spawn(function()
                local eggCF = getEggCFrame(State.selectedEggName)
                local char  = player.Character
                local hrp   = char and char:FindFirstChild("HumanoidRootPart")
                if hrp and eggCF then
                    local ep = eggCF.Position
                    hrp.CFrame = CFrame.lookAt(ep+Vector3.new(0,10,3), Vector3.new(ep.X,ep.Y+10,ep.Z))
                    hrp.AssemblyLinearVelocity  = Vector3.zero
                    hrp.AssemblyAngularVelocity = Vector3.zero
                end
                task.wait(0.5)
                while State.isAutoEgg do
                    if State.pauseForGauntlet then task.wait(1) continue end
                    local returnCF = getBestReturnCFrame()
                    if (State.isAutoFarm or State.isAutoSnipeBoss) and returnCF then
                        char = player.Character
                        hrp  = char and char:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            hrp.CFrame = returnCF
                            hrp.AssemblyLinearVelocity  = Vector3.zero
                            hrp.AssemblyAngularVelocity = Vector3.zero
                        end
                        local farmEnd = tick()+3
                        while tick()<farmEnd and State.isAutoEgg and not State.pauseForGauntlet do task.wait(0.05) end
                        if not State.isAutoEgg or State.pauseForGauntlet then continue end
                        State.isDoingEgg = true
                        task.wait(0.15)
                        eggCF = getEggCFrame(State.selectedEggName)
                        char  = player.Character
                        hrp   = char and char:FindFirstChild("HumanoidRootPart")
                        if hrp and eggCF then
                            local ep = eggCF.Position
                            hrp.CFrame = CFrame.lookAt(ep+Vector3.new(0,10,3), Vector3.new(ep.X,ep.Y+10,ep.Z))
                            hrp.AssemblyLinearVelocity  = Vector3.zero
                            hrp.AssemblyAngularVelocity = Vector3.zero
                        end
                        task.wait(1.5)
                        pcall(function() Remote.OpenEgg:FireServer(State.selectedEggName,true) end)
                        task.wait(1.5)
                        char = player.Character
                        hrp  = char and char:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            hrp.CFrame = returnCF
                            hrp.AssemblyLinearVelocity  = Vector3.zero
                            hrp.AssemblyAngularVelocity = Vector3.zero
                        end
                        State.isDoingEgg = false
                    else
                        eggCF = getEggCFrame(State.selectedEggName)
                        char  = player.Character
                        hrp   = char and char:FindFirstChild("HumanoidRootPart")
                        if hrp and eggCF then
                            local ep    = eggCF.Position
                            local myPos = hrp.Position
                            if (Vector3.new(myPos.X,0,myPos.Z)-Vector3.new(ep.X,0,ep.Z)).Magnitude > 10 then
                                hrp.CFrame = CFrame.lookAt(ep+Vector3.new(0,10,3), Vector3.new(ep.X,ep.Y+10,ep.Z))
                                hrp.AssemblyLinearVelocity  = Vector3.zero
                                hrp.AssemblyAngularVelocity = Vector3.zero
                                task.wait(1.5)
                            end
                        end
                        pcall(function() Remote.OpenEgg:FireServer(State.selectedEggName,true) end)
                        task.wait(0.5)
                    end
                end
                State.isDoingEgg = false
            end)
        else
            State.isDoingEgg = false
        end
    end
})

