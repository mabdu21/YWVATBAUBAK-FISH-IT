local function findEnemyMulti(nameList)
    if not EnemiesFolder then return nil end
    local allow = {}
    for _, n in ipairs(nameList) do allow[n] = true end
    local myPos = (player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        and player.Character.HumanoidRootPart.Position) or Vector3.zero
    local best, bestDist = nil, math.huge
    for _, e in ipairs(EnemiesFolder:GetChildren()) do
        if e:GetAttribute("dead") == true then continue end
        local ui = PlayerGui:FindFirstChild("enemy-overhead-" .. e.Name)
        if ui and ui:FindFirstChild("Frame") and ui.Frame:FindFirstChild("TextLabel") then
            local rn = ui.Frame.TextLabel.Text
            if next(allow) == nil or allow[rn] then
                local cf = getEnemyCFrame(e)
                if cf then
                    local d = (cf.Position - myPos).Magnitude
                    if d < bestDist then bestDist = d best = e end
                end
            end
        end
    end
    return best
end

local function findNearestAnyEnemy()
    local wf = WS:FindFirstChild("World") and WS.World:FindFirstChild("Enemies")
    if not wf then return nil end
    local myPos = (player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        and player.Character.HumanoidRootPart.Position) or Vector3.zero
    local best, bestDist = nil, math.huge
    for _, e in ipairs(wf:GetChildren()) do
        if e:GetAttribute("dead") == true then continue end
        local cf = getEnemyCFrame(e)
        if cf then
            local d = (cf.Position - myPos).Magnitude
            if d < bestDist then bestDist = d best = e end
        end
    end
    return best
end

local function findNearestEnemyInRange(range)
    local char  = player.Character
    local hrp   = char and char:FindFirstChild("HumanoidRootPart")
    local myPos = hrp and hrp.Position or Vector3.zero
    local best, bestDist = nil, math.huge
    local enemiesFolder = WS:FindFirstChild("World") and WS.World:FindFirstChild("Enemies")
    if not enemiesFolder then return nil end
    for _, e in ipairs(enemiesFolder:GetChildren()) do
        if e:GetAttribute("dead") == true then continue end
        local h = e:FindFirstChildOfClass("Humanoid")
        if not h or h.Health <= 0 then continue end
        local cf = getEnemyCFrame(e)
        if not cf then continue end
        local d = (cf.Position - myPos).Magnitude
        if d <= range and d < bestDist then
            bestDist = d
            best     = e
        end
    end
    return best
end

local function attackTarget(target, allowListGetter, maxSeconds)
    local lastActionTick = 0
    local startTick       = tick()
    maxSeconds             = maxSeconds or 25

    while (State.isAutoFarm or State.isAutoSnipeBoss) and target and target.Parent do
        if target:GetAttribute("dead") == true then break end
        if State.pauseForGauntlet then break end
        if tick() - startTick > maxSeconds then break end

        if allowListGetter then
            local allowList = allowListGetter()
            if allowList and #allowList > 0 then
                local realName = getEnemyRealNameSimple(target)
                local stillAllowed = false
                for _, n in ipairs(allowList) do
                    if n == realName then stillAllowed = true break end
                end
                if not stillAllowed then break end
            end
        end

        local char      = player.Character
        local hrp       = char and char:FindFirstChild("HumanoidRootPart")
        local myUnits   = getMyUnits()
        local targetPos = getEnemyCFrame(target)
        if targetPos then
            if hrp then
                hrp.CFrame = targetPos * CFrame.new(0, 5, 0)
                hrp.AssemblyLinearVelocity = Vector3.zero
                State.lastFarmCFrame = hrp.CFrame
            end
            if tick() - lastActionTick >= 0.2 then
                lastActionTick = tick()
                teleportUnitsTo(targetPos)
                pcall(function() Remote.SendUnit:FireServer(target.Name, myUnits) end)
            end
        end
        task.wait()
    end
end

