task.spawn(function()
    task.wait(5)
    while isRunning() do
        if not State.isGauntletFarm then task.wait(2) continue end
        local now       = os.time()
        local secInHour = now % 3600
        local secToNext = 3600 - secInHour
        local WINDOW    = 300
        if secInHour <= WINDOW then
            if State.isGauntletFarm then
                savePositionBeforeGauntlet()
                if State.preGauntletCFrame then State.savedFarmCFrame = State.preGauntletCFrame end
            end
            WindUI:Notify({Title="Gauntlet Window Open!",
                Content=string.format("Window open — %ds remaining!", WINDOW-secInHour), Duration=5})
        elseif secToNext > 10 then
            local waitTime = secToNext - 10
            WindUI:Notify({Title="Gauntlet Scheduler",
                Content=string.format("Next Gauntlet in %02d:%02d",
                    math.floor(waitTime/60), waitTime%60),
                Duration=math.min(waitTime,8)})
            task.wait(waitTime)
            if State.isGauntletFarm then
                savePositionBeforeGauntlet()
                if State.preGauntletCFrame then State.savedFarmCFrame = State.preGauntletCFrame end
            end
        end
        if not State.isGauntletFarm then continue end
        State.pauseForGauntlet = true
        State.gauntletRunning  = true
        WindUI:Notify({Title="Gauntlet Time!", Content="Pausing Raid & AutoEgg!", Duration=5})
        task.wait(5)
        pcall(runOneGauntletRound)
        State.gauntletRunning  = false
        task.wait(1)
        restorePositionAfterGauntlet()
        State.pauseForGauntlet = false
        WindUI:Notify({Title="Gauntlet Done", Content="Resuming!", Duration=4})
        State.preGauntletCFrame = nil
        task.wait(65)
    end
end)

