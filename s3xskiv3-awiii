    end
end

local function startQueueRunner()
    if State.isQueueRunning then return end
    if not State.isAutoRaidEnabled then return end
    State.isQueueRunning = true
    Thread.queueRunner = task.spawn(function()
        while true do
            if not State.isAutoRaidEnabled then State.isQueueRunning=false Thread.queueRunner=nil return end
            if #getActiveRaids() == 0 then State.isQueueRunning=false Thread.queueRunner=nil return end
            if State.pauseForGauntlet then
                while State.pauseForGauntlet do task.wait(1) end
            end
            local raidName, waitSec = pickNextRaid()
            if not raidName then task.wait(5) continue end
            if waitSec > 0 then
                local mins = math.floor(waitSec/60)
                local secs = math.floor(waitSec%60)
                WindUI:Notify({
                    Title   = "All Raids on Cooldown",
                    Content = string.format("Next: [%s] in %02d:%02d", raidName, mins, secs),
                    Duration = 6,
                })
                local waited, target2 = 0, waitSec + 2
                while waited < target2 do
                    task.wait(5) waited += 5
                    pcall(updateRaidStatus)
                    if not State.isAutoRaidEnabled then State.isQueueRunning=false Thread.queueRunner=nil return end
                    if State.pauseForGauntlet then while State.pauseForGauntlet do task.wait(1) end end
                    local nr, nw = pickNextRaid()
                    if nw == 0 then raidName = nr break end
                    if #getActiveRaids() == 0 then State.isQueueRunning=false Thread.queueRunner=nil return end
                end
                if Data.RaidCooldowns[raidName] and tick() >= Data.RaidCooldowns[raidName] then
                    Data.RaidCooldowns[raidName] = nil
                end
            end
            if not Data.RaidStates[raidName] then continue end
            if not State.isAutoRaidEnabled then continue end
            local wasFarming = State.isAutoFarm or State.isAutoSnipeBoss
            if wasFarming then
                updateLastFarmPosition()
                State.isAutoFarm      = false
                State.isAutoSnipeBoss = false
                pcall(function()
                    Remote.SetState:FireServer("attack",false)
                    Remote.SetState:FireServer("clicker",false)
                end)
                task.wait(0.5)
            end
            local function resumeFarm()
                if not wasFarming then return end
                State.isAutoFarm      = true
                State.isAutoSnipeBoss = true
                pcall(function()
                    Remote.SetState:FireServer("attack",true)
                    Remote.SetState:FireServer("clicker",true)
                end)
                spawnFarmLoops()
            end
            task.wait(1)
            local raidOpen, raidStatus, cdLeft, teleported = checkRaidOpenAtPortal(raidName)
            pcall(updateRaidStatus)
            if not teleported and not Data.RaidNoPortal[raidName] then
                WindUI:Notify({Title=string.format("[%s] Portal Not Found",raidName), Content="Skipping...", Duration=4})
                Data.RaidCooldowns[raidName] = tick() + 20
                resumeFarm() continue
            end
            if not raidOpen then
                local waitP = cdLeft or 120
                if waitP <= 90 then
                    WindUI:Notify({Title=string.format("[%s] Opening Soon",raidName),
                        Content=string.format("Waiting %ds...",math.max(1,waitP)), Duration=4})
                    local w = 0
                    while w < waitP+3 and Data.RaidStates[raidName] and State.isAutoRaidEnabled do
                        task.wait(1) w += 1
                        if State.pauseForGauntlet then break end
                    end
                    raidOpen, raidStatus, cdLeft = checkRaidOpenAtPortal(raidName)
                end
                if not raidOpen then
                    local store = cdLeft and math.max(cdLeft,30) or 60
                    Data.RaidCooldowns[raidName] = tick() + store
                    WindUI:Notify({Title=string.format("[%s] Closed",raidName),
                        Content=string.format("Status: %s", raidStatus or "?"), Duration=3})
                    pcall(updateRaidStatus) resumeFarm() continue
                end
            end
            if not Data.RaidStates[raidName] or not State.isAutoRaidEnabled or State.pauseForGauntlet then continue end
            WindUI:Notify({Title=string.format("[%s] Raid Open!",raidName), Content="Loading team...", Duration=3})
            loadTeam(State.raidTeamSlot) task.wait(1)
            loadTeam(State.raidTeamSlot) task.wait(2)
            pcall(function()
                Remote.BossRaidCreate:InvokeServer(raidName, {friendsOnly=false, spawnNormal=false})
            end)
            task.wait(2)
            pcall(function() Remote.LobbiesStart:FireServer() end)
            task.wait(3)
            pcall(function()
                Remote.SetState:FireServer("attack",true)
                Remote.SetState:FireServer("clicker",true)
            end)
            runSingleRaid(raidName, function()
                return Data.RaidStates[raidName] and State.isAutoRaidEnabled and not State.pauseForGauntlet
            end)
            pcall(function()
                Remote.SetState:FireServer("attack",false)
                Remote.SetState:FireServer("clicker",false)
            end)
            pcall(function() Remote.BossRaidLeave:FireServer() end)
            WindUI:Notify({Title=string.format("[%s] Done!",raidName), Content="Waiting 60s...", Duration=5})
            if wasFarming then
                task.wait(2)
                State.isAutoFarm      = true
                State.isAutoSnipeBoss = true
                pcall(function()
                    Remote.SetState:FireServer("attack",true)
                    Remote.SetState:FireServer("clicker",true)
                end)
                spawnFarmLoops()
            end
            task.wait(58)
            Data.RaidCooldowns[raidName] = tick() + CONST.RAID_COOLDOWN_SEC
            pcall(updateRaidStatus)
            WindUI:Notify({Title=string.format("[%s] CD 20min",raidName), Content="Next raid...", Duration=3})
        end
    end)
end

