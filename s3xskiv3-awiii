local function isInfiltVictoryVisible()
    for _, rg in ipairs({PlayerGui, Svc.CoreGui}) do
        for _, g in ipairs(rg:GetDescendants()) do
            if (g:IsA("TextLabel") or g:IsA("TextButton")) and g.Visible and isGuiActuallyVisible(g) then
                local t = tostring(g.Text or ""):lower()
                if (t:find("victory") or t:find("infiltration complete"))
                   and not t:find("restarting") then return true end
            end
        end
    end
    return false
end

local function runOneInfiltrationRound(name, path, isActiveFunc)
    WindUI:Notify({
        Title    = string.format("[Infiltration] %s — Path %s", name, path),
        Content  = "Loading team & entering...",
        Duration = 4,
    })
    loadTeam(State.infiltTeamSlot) task.wait(1)
    loadTeam(State.infiltTeamSlot) task.wait(2)
    local ok = pcall(function()
        Remote.InfiltCreate:InvokeServer(name, path, {friendsOnly=false})
    end)
    if not ok then pcall(function() Remote.InfiltCreate:FireServer(name, path, {friendsOnly=false}) end) end
    task.wait(2)
    pcall(function() Remote.LobbiesStart:FireServer() end)
    task.wait(3)
    pcall(function()
        Remote.SetState:FireServer("attack",true)
        Remote.SetState:FireServer("clicker",true)
    end)

    local roundStart = tick()
    local noETimer   = 0
    local lastATick  = 0
    local RANGE      = CONST.INFILT_ENEMY_RANGE

    WindUI:Notify({
        Title    = string.format("[%s] Path %s — Farming!", name, path),
        Content  = string.format("Attacking enemies in %d studs range...", RANGE),
        Duration = 4,
    })

    while isActiveFunc() do
        if tick()-roundStart > 25*60 then
            WindUI:Notify({Title="[Infiltration] Timed Out", Content="25 min limit.", Duration=4})
            break
        end
        if isInfiltVictoryVisible() then
            WindUI:Notify({
                Title   = string.format("[%s] Path %s — Victory!", name, path),
                Content = "Round complete! Restarting...",
                Duration = 4,
            })
            task.wait(5)
            break
        end
        if State.pauseForGauntlet then
            WindUI:Notify({Title="[Infiltration] Paused", Content="Gauntlet priority!", Duration=3})
            while State.pauseForGauntlet and isActiveFunc() do task.wait(1) end
            WindUI:Notify({Title="[Infiltration] Resumed", Content="Continuing...", Duration=3})
        end

        local target = findNearestEnemyInRange(RANGE)
        if not target then
            noETimer += 0.2
            if noETimer >= 8 then
                noETimer = 0
                WindUI:Notify({Title="[Infiltration] Waiting...", Content="No enemies nearby — next wave?", Duration=3})
            end
            task.wait(0.2)
            continue
        end
        noETimer = 0

        while isActiveFunc() do
            if State.pauseForGauntlet then break end
            if isInfiltVictoryVisible() then break end
            if not target or not target.Parent then break end

            local h = target:FindFirstChildOfClass("Humanoid")
            if target:GetAttribute("dead") == true or (h and h.Health <= 0) then
                local nxt = findNearestEnemyInRange(RANGE)
                if nxt then target = nxt else break end
            end

            local char  = player.Character
            local hrp   = char and char:FindFirstChild("HumanoidRootPart")
            local units = getMyUnits()
            local tPos  = getEnemyCFrame(target)

            if tPos and hrp then
                if (hrp.Position - tPos.Position).Magnitude > RANGE then break end
                hrp.CFrame = tPos * CFrame.new(0, 5, 0)
                hrp.AssemblyLinearVelocity  = Vector3.zero
                hrp.AssemblyAngularVelocity = Vector3.zero
                if tick()-lastATick >= 0.15 then
                    lastATick = tick()
                    teleportUnitsTo(tPos)
                    pcall(function() Remote.SendUnit:FireServer(target.Name, units) end)
                end
            end
            task.wait(0.08)
        end
    end

    pcall(function()
        Remote.SetState:FireServer("attack",false)
        Remote.SetState:FireServer("clicker",false)
    end)
    pcall(function()
        local lr = RemoContainer:FindFirstChild("infiltration.leave")
                or RemoContainer:FindFirstChild("lobbies.leave")
        if lr then lr:FireServer() end
    end)
    task.wait(3)
end

local function startInfiltrationLoop()
    if Thread.infiltration then
        pcall(function() task.cancel(Thread.infiltration) end)
        Thread.infiltration = nil
    end
    Thread.infiltration = task.spawn(function()
        local round = 0
        while State.isAutoInfiltration do
            round += 1
            WindUI:Notify({
                Title   = string.format("[Infiltration] Round #%d", round),
                Content = string.format("%s — Path %s", State.selectedInfiltName, State.selectedInfiltPath),
                Duration = 3,
            })
            while State.pauseForGauntlet and State.isAutoInfiltration do task.wait(1) end
            if not State.isAutoInfiltration then break end
            runOneInfiltrationRound(
                State.selectedInfiltName,
                State.selectedInfiltPath,
                function() return State.isAutoInfiltration and not State.pauseForGauntlet end
            )
            if State.isAutoInfiltration then task.wait(5) end
        end
        WindUI:Notify({Title="[Infiltration] Stopped", Content="Auto Infiltration disabled.", Duration=3})
    end)
end

local function stopInfiltrationLoop()
    State.isAutoInfiltration = false
    if Thread.infiltration then
        pcall(function() task.cancel(Thread.infiltration) end)
        Thread.infiltration = nil
    end
    pcall(function()
        Remote.SetState:FireServer("attack",false)
        Remote.SetState:FireServer("clicker",false)
    end)
end

