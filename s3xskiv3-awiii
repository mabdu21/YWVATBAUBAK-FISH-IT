local function getLocationNames()
    local names = {}
    pcall(function()
        local locs = WS:FindFirstChild("World") and WS.World:FindFirstChild("Teleports")
            and WS.World.Teleports:FindFirstChild("Locations")
        if locs then
            local function norm(s) return s:lower():gsub("[%-%_ ]","") end
            local wn = {}
            for _, n in ipairs(worldNames) do wn[norm(n)]=true end
            for _, l in ipairs(locs:GetChildren()) do
                if not wn[norm(l.Name)] then table.insert(names, l.Name) end
            end
            table.sort(names)
        end
    end)
    if #names==0 then names={"(No extra locations)"} end
    return names
end

