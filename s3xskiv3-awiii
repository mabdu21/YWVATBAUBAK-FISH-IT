local function findEscortCart()
    local map = WS:FindFirstChild("World") and WS.World:FindFirstChild("Map")
    if not map then return nil end
    for _, child in ipairs(map:GetChildren()) do
        if child.Name:sub(1,7) == "escort-" then
            local cart = child:FindFirstChild("Cart",true)
            if cart then
                local root = cart:FindFirstChild("root")
                if root and root:IsA("BasePart") then return root end
                if cart:IsA("BasePart") then return cart end
                if cart.PrimaryPart then return cart.PrimaryPart end
                for _, p in ipairs(cart:GetDescendants()) do
                    if p:IsA("BasePart") then return p end
                end
            end
            local root = child:FindFirstChild("root",true)
            if root and root:IsA("BasePart") then return root end
        end
    end
    return nil
end

