    Icon     = "navigation",
    Callback = function()
        if selectedWorld=="" or selectedWorld=="(No worlds found)" then
            WindUI:Notify({Title="World", Content="No world selected!", Duration=3}) return
        end
        local ok2 = false
        pcall(function()
            local locs = WS:FindFirstChild("World") and WS.World:FindFirstChild("Teleports")
                and WS.World.Teleports:FindFirstChild("Locations")
            if not locs then return end
            local function norm(s) return s:lower():gsub("[%-%_ ]","") end
            local loc = locs:FindFirstChild(selectedWorld)
            if not loc then
                local tn = norm(selectedWorld)
                for _, c in ipairs(locs:GetChildren()) do
                    if norm(c.Name)==tn then loc=c break end
                end
            end
            if loc then
                local cf
                if loc:IsA("Model") then
                    if loc.PrimaryPart then cf=loc.PrimaryPart.CFrame
                    else pcall(function() cf=loc:GetPivot() end) end
                elseif loc:IsA("BasePart") then cf=loc.CFrame end
                if cf then
                    local char = player.Character
                    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        hrp.CFrame = cf * CFrame.new(0,5,0)
                        hrp.AssemblyLinearVelocity  = Vector3.zero
                        hrp.AssemblyAngularVelocity = Vector3.zero
                        ok2 = true
                    end
                end
            end
        end)
        WindUI:Notify({Title="World",
            Content=ok2 and ("Teleported to "..selectedWorld) or ("Not found: "..selectedWorld), Duration=3})
    end
})

