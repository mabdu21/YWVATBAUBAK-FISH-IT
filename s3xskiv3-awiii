local function getRaidPortalLabel(raidName)
    local parts = CONST.RAID_PORTAL_PATHS[raidName]
    if not parts then return nil end
    local map = WS:WaitForChild("World",3):FindFirstChild("Map")
    if not map then return nil end
    local node = map
    for _, p in ipairs(parts) do
        node = node:FindFirstChild(p)
        if not node then return nil end
    end
    return node
end

local function getRaidPortalCFrame(raidName)
    local parts = CONST.RAID_PORTAL_PATHS[raidName]
    if not parts then return nil end
    local map = WS:WaitForChild("World", 3):FindFirstChild("Map")
    if not map then return nil end
    local node = map
    for i = 1, math.min(4, #parts) do
        node = node:FindFirstChild(parts[i])
        if not node then node = nil break end
    end
    local cf = node and getInstanceCFrame(node)
    if cf then return cf end
    node = map
    for i = 1, math.min(3, #parts) do
        node = node:FindFirstChild(parts[i])
        if not node then node = nil break end
    end
    cf = node and getInstanceCFrame(node)
    if cf then return cf end
    local worldName = parts[1]
    local locations = WS:FindFirstChild("World")
        and WS.World:FindFirstChild("Teleports")
        and WS.World.Teleports:FindFirstChild("Locations")
    local worldLocation = locations and worldName and locations:FindFirstChild(worldName)
    cf = worldLocation and getInstanceCFrame(worldLocation)
    if cf then return cf end
    local labelNode = getRaidPortalLabel(raidName)
    while labelNode do
        cf = getInstanceCFrame(labelNode)
        if cf then return cf end
        labelNode = labelNode.Parent
    end
    return nil
end

local function teleportToRaidPortal(raidName)
    local cf = getRaidPortalCFrame(raidName)
    if not cf then return false end
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp  = char and char:WaitForChild("HumanoidRootPart", 3)
    if not hrp then return false end
    local targetPos = cf.Position + Vector3.new(0, 5, 8)
    hrp.CFrame = CFrame.lookAt(targetPos, cf.Position)
    hrp.AssemblyLinearVelocity  = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero
    return true
end

local function getRaidStatusFromPortal(raidName)
    local node = getRaidPortalLabel(raidName)
    if not node then return nil end
    local text = (node.Text or ""):gsub("<[^>]+>",""):gsub("^%s+",""):gsub("%s+$","")
    return text:match("[^\n]+$") or text
end

local function getRaidCDFromStatus(status)
    if type(status) ~= "string" then return nil end
    local low = status:lower()
    if not low:find("open in") then return nil end
    local m, s = low:match("(%d+)%s*:%s*(%d+)")
    if m and s then return (tonumber(m) or 0)*60 + (tonumber(s) or 0) end
    local sec = low:match("open in:%s*(%d+)")
    if sec then return tonumber(sec) end
    return nil
end

local function isRaidOpen(raidName)
    if not CONST.RAID_PORTAL_PATHS[raidName] then return true end
    local ok, res = pcall(function()
        local plain = getRaidStatusFromPortal(raidName)
        if not plain then return nil end
        if plain:lower():find("open in") then return false end
        return plain:match("%f[%a]Open%f[%A]") ~= nil
    end)
    if ok and res ~= nil then return res end
    return false
end

local function checkRaidOpenAtPortal(raidName)
    if Data.RaidNoPortal[raidName] then
        WindUI:Notify({
            Title   = string.format("[%s] No Portal", raidName),
            Content = "noPortal raid — joining directly!",
            Duration = 3,
        })
