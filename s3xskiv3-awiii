local function getCurrentFloor()
    for _, v in ipairs(game:GetDescendants()) do
        if v:IsA("TextLabel") then
            local floor = tostring(v.Text or ""):match("Floor%s*(%d+)")
            if floor then return tonumber(floor) end
        end
    end
    return 0
end

local function leaveGauntlet()
    if Remote.GauntletLeave then
        pcall(function() Remote.GauntletLeave:FireServer() end)
        task.wait(0.5)
    end
    for _, gui in ipairs(PlayerGui:GetChildren()) do
        for _, btn in ipairs(gui:GetDescendants()) do
            if btn:IsA("GuiButton") then
                local t = (btn.Text or ""):lower()
                if t == "quit" or t == "leave" or t == "exit" then
                    pcall(function() btn.Activated:Fire() end)
                    pcall(function() btn:Activate() end)
                    task.wait(0.5) return
                end
            end
        end
    end
    pcall(function()
        local lr = RemoContainer:FindFirstChild("lobbies.leave")
        if lr then lr:FireServer() end
    end)
end

local function findGauntletCardsObject()
    local map = WS:FindFirstChild("World") and WS.World:FindFirstChild("Map")
    if not map then return nil end
    local bestFloor, bestCards = -1, nil
    for _, mc in ipairs(map:GetChildren()) do
        if mc.Name:sub(1,9) == "gauntlet-" then
            for _, fc in ipairs(mc:GetChildren()) do
                local n = fc.Name:match("^floor%-(%d+)$")
                if n then
                    local cards = fc:FindFirstChild("GauntletCards")
                    if cards then
                        local fn = tonumber(n)
                        if fn > bestFloor then bestFloor=fn bestCards=cards end
                    end
                end
            end
        end
    end
    return bestCards
end

local function teleportAndInteractCards(cardsObj)
    if not cardsObj then return end
    local char = player.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local cf
    if cardsObj:IsA("Model") then
        if cardsObj.PrimaryPart then cf = cardsObj.PrimaryPart.CFrame
        else pcall(function() cf = cardsObj:GetPivot() end) end
    elseif cardsObj:IsA("BasePart") then
        cf = cardsObj.CFrame
    else
        for _, c in ipairs(cardsObj:GetDescendants()) do
            if c:IsA("BasePart") then cf = c.CFrame break end
        end
    end
    if cf then
        hrp.CFrame = cf * CFrame.new(0,4,3)
        hrp.AssemblyLinearVelocity  = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
        task.wait(0.4)
    end
    for _, c in ipairs(cardsObj:GetDescendants()) do
        if c:IsA("BasePart") then
            pcall(function() local cd = c:FindFirstChildOfClass("ClickDetector") if cd then fireclickdetector(cd) end end)
            pcall(function() local pp = c:FindFirstChildOfClass("ProximityPrompt") if pp then fireproximityprompt(pp) end end)
            pcall(function()
                local hrp2 = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if hrp2 then c.Touched:Fire(hrp2) end
            end)
        end
    end
end

local function pickBestCard(available)
    for _, pri in ipairs(State.cardPriorityList) do
        if pri and pri ~= "" then
            for _, card in ipairs(available) do
                if card.baseName == pri
                or card.baseName:sub(1,#pri) == pri
                or pri:sub(1,#card.baseName) == card.baseName then
                    return card.fullName
                end
            end
        end
    end
    return available[1] and available[1].fullName or nil
end

local function doCardSelection()
    if State.isCardSelecting then return end
    State.isCardSelecting = true
    local cardsObj = findGauntletCardsObject()
    if cardsObj then teleportAndInteractCards(cardsObj) task.wait(0.5) end
    pcall(function() Remote.GauntletCards:FireServer() end)
    task.wait(1.5)
    local function getBaseName(t) return (t:gsub("%s+[IVX]+$","")) end
    local function scanForCards()
        local found, seenFull = {}, {}
        for _, gui in ipairs(PlayerGui:GetChildren()) do
            for _, lbl in ipairs(gui:GetDescendants()) do
                if lbl:IsA("TextLabel") or lbl:IsA("TextButton") then
                    local t = (lbl.Text or ""):match("^%s*(.-)%s*$")
                    if t ~= "" and not seenFull[t] then
                        local base = getBaseName(t)
                        for _, cn in ipairs(Data.ALL_CARDS) do
                            if base == cn then
                                seenFull[t] = true
                                table.insert(found, {fullName=t, baseName=base})
                                break
                            end
                        end
                    end
                end
            end
        end
        return found
    end
    local shown = {}
    local scanEnd = tick() + 8
    while tick() < scanEnd do
        shown = scanForCards()
        if #shown > 0 then break end
        if cardsObj then teleportAndInteractCards(cardsObj) end
        pcall(function() Remote.GauntletCards:FireServer() end)
        task.wait(0.5)
    end
    if #shown == 0 then
        for _, cn in ipairs(Data.ALL_CARDS) do
            table.insert(shown, {fullName=cn, baseName=cn})
        end
    end
    local chosen = pickBestCard(shown)
    if chosen then
        pcall(function() Remote.GauntletVote:FireServer(chosen) end)
        task.wait(0.3)
        WindUI:Notify({Title="Card Selected", Content="Selected: "..chosen, Duration=3})
    end
    pcall(function() Remote.GauntletClear:FireServer() end)
    task.wait(0.5)
    State.isCardSelecting = false
end

local function attackNearestEnemyOnce()
    local best = findNearestAnyEnemy()
    if not best then return end
    local char  = player.Character
    local hrp   = char and char:FindFirstChild("HumanoidRootPart")
    local units = getMyUnits()
    local tPos  = getEnemyCFrame(best)
    if tPos then
        if hrp then hrp.CFrame = tPos * CFrame.new(0,5,0) hrp.AssemblyLinearVelocity = Vector3.zero end
        teleportUnitsTo(tPos)
        pcall(function() Remote.SendUnit:FireServer(best.Name, units) end)
    end
end

local function runOneGauntletRound()
    loadTeam(State.gauntletTeamSlot) task.wait(1)
    loadTeam(State.gauntletTeamSlot) task.wait(2)
    pcall(function() Remote.GauntletCreate:InvokeServer("Normal", {friendsOnly=false}) end)
    task.wait(1.5)
    pcall(function() Remote.LobbiesStart:FireServer() end)
    task.wait(2)
    pcall(function()
        Remote.SetState:FireServer("attack",true)
        Remote.SetState:FireServer("clicker",true)
    end)
    task.wait(3)
    local lastCardFloor, attackTick = -1, 0
    while State.isGauntletFarm do
        local floor = getCurrentFloor()
        if State.isGauntletAutoLeave and floor > 0 and floor >= State.gauntletMaxFloor then
            pcall(function()
                Remote.SetState:FireServer("attack",false)
                Remote.SetState:FireServer("clicker",false)
            end)
            WindUI:Notify({Title="Auto Leave",
                Content=string.format("Floor %d / %d — leaving!",floor,State.gauntletMaxFloor), Duration=5})
            task.wait(5) leaveGauntlet() task.wait(3) break
        end
        if State.isGauntletAutoCard and floor > 0 and floor%5==0 and floor~=lastCardFloor then
            lastCardFloor = floor
            task.spawn(doCardSelection)
        end
        if tick()-attackTick >= 0.15 then
            attackTick = tick()
            pcall(attackNearestEnemyOnce)
        end
        task.wait(0.05)
    end
    pcall(function()
        Remote.SetState:FireServer("attack",false)
        Remote.SetState:FireServer("clicker",false)
    end)
end

