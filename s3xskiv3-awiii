local function getEnemyCFrame(entity)
    if not entity then return nil end
    local hrp = entity:FindFirstChild("HumanoidRootPart")
    if hrp then return hrp.CFrame end
    if entity:IsA("Model") then
        if entity.PrimaryPart then return entity.PrimaryPart.CFrame end
        local ok, cf = pcall(function() return entity:GetPivot() end)
        if ok then return cf end
    elseif entity:IsA("BasePart") then
        return entity.CFrame
    end
    for _, c in ipairs(entity:GetDescendants()) do
        if c.Name == "HumanoidRootPart" and c:IsA("BasePart") then return c.CFrame end
    end
    for _, c in ipairs(entity:GetDescendants()) do
        if c:IsA("BasePart") then return c.CFrame end
    end
    return nil
end

local function isEnemyAlive(enemy)
    if enemy:GetAttribute("dead") == true then return false end
    local h = enemy:FindFirstChildOfClass("Humanoid")
    if h and h.Health <= 0 then return false end
    return true
end

local function getMyUnits()
    local units = {}
    local wf = WS:FindFirstChild("World") and WS.World:FindFirstChild("Warriors")
    if wf then
        for _, w in ipairs(wf:GetChildren()) do
            if w:GetAttribute("Owner") == player.Name or w.Name == player.Name then
                if w.Name == player.Name then
                    for _, c in ipairs(w:GetChildren()) do table.insert(units, c.Name) end
                else
                    table.insert(units, w.Name)
                end
            end
        end
    end
    return units
end

local function teleportUnitsTo(targetCF)
    local wf = WS:FindFirstChild("World") and WS.World:FindFirstChild("Warriors")
    if not wf then return end
    for _, w in ipairs(wf:GetChildren()) do
        if w:GetAttribute("Owner") == player.Name or w.Name == player.Name then
            if w.Name == player.Name then
                for _, c in ipairs(w:GetChildren()) do
                    if c:IsA("Model") then pcall(function() c:PivotTo(targetCF) end) end
                end
            else
                if w:IsA("Model") then pcall(function() w:PivotTo(targetCF) end) end
            end
        end
    end
end

