local function spawnFarmLoops()
    local returnCF = getBestReturnCFrame()
    if returnCF then
        local char = player.Character or player.CharacterAdded:Wait()
        local hrp  = char and char:WaitForChild("HumanoidRootPart",5)
        if hrp then
            hrp.CFrame = returnCF
            hrp.AssemblyLinearVelocity  = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
        end
    end
    task.spawn(function()
        while State.isAutoFarm do
            if State.pauseForGauntlet or State.isAutoSnipeBoss then task.wait(1) continue end
            if #State.selectedEnemyNames == 0 then task.wait(1) continue end
            local t = findEnemyMulti(State.selectedEnemyNames)
            if t then
                attackTarget(t, function() return State.selectedEnemyNames end, 25)
            else
                task.wait(0.1)
            end
        end
        if not State.isAutoSnipeBoss then
            pcall(function()
                Remote.SetState:FireServer("attack",false)
                Remote.SetState:FireServer("clicker",false)
            end)
        end
    end)
    task.spawn(function()
        while State.isAutoSnipeBoss do
            if State.pauseForGauntlet then task.wait(1) continue end
            if #State.selectedBossNames == 0 then task.wait(1) continue end
            local myPos = (player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                and player.Character.HumanoidRootPart.Position) or Vector3.zero
            local best, bestD = nil, math.huge
            for _, bn in ipairs(State.selectedBossNames) do
                local t = getTargetEnemy(bn)
                if t then
                    local cf = getEnemyCFrame(t)
                    if cf then
                        local d = (cf.Position - myPos).Magnitude
                        if d < bestD then bestD=d best=t end
                    end
                end
            end
            if best then
                attackTarget(best, function() return State.selectedBossNames end, 60)
            else
                task.wait(1)
            end
        end
        if not State.isAutoFarm then
            pcall(function()
                Remote.SetState:FireServer("attack",false)
                Remote.SetState:FireServer("clicker",false)
            end)
        end
    end)
end

