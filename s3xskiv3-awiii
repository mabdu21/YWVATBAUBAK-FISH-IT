local function getAllRaidEnemies()
    local res = {}
    local char = player.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    local myPos = hrp and hrp.Position or Vector3.zero
    local wf = WS:FindFirstChild("World") and WS.World:FindFirstChild("Enemies")
    if wf then
        for _, e in ipairs(wf:GetChildren()) do
            if not isEnemyAlive(e) then continue end
            local cf = getEnemyCFrame(e)
            if cf then
                local d = (cf.Position - myPos).Magnitude
                if d <= CONST.RAID_MAX_RANGE then
                    table.insert(res, {obj=e, dist=d, realName=getEnemyRealName(e)})
                end
            end
        end
    end
    table.sort(res, function(a,b) return a.dist < b.dist end)
    return res
end

local function findRaidEnemyByName(name)
    local wf = WS:FindFirstChild("World") and WS.World:FindFirstChild("Enemies")
    if not wf then return nil end
    local char = player.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    local myPos = hrp and hrp.Position or Vector3.zero
    local nl = name:lower()
    local best, bestDist = nil, math.huge
    for _, e in ipairs(wf:GetChildren()) do
        if not isEnemyAlive(e) then continue end
        local cf = getEnemyCFrame(e)
        if not cf then continue end
        local d = (cf.Position - myPos).Magnitude
        if d > CONST.RAID_MAX_RANGE then continue end
        local rn = getEnemyRealName(e):lower()
        if rn:find(nl,1,true) or nl:find(rn,1,true) then
            if d < bestDist then bestDist = d best = e end
        end
    end
    return best
end

local function pickRaidTarget(raidName)
    ensureRaidConfig(raidName)
    local cfg = Data.RaidConfig[raidName]
    local all = getAllRaidEnemies()
    local function findByName(n)
        local nl = n:lower()
        for _, e in ipairs(all) do
            if e.realName:lower():find(nl,1,true) or nl:find(e.realName:lower(),1,true) then
                return e.obj
            end
        end
        return nil
    end
    for _, ln in ipairs(cfg.light) do
        local e = findByName(ln)
        if e then return e, "light" end
    end
    if cfg.tank then
        local e = findByName(cfg.tank)
        if e then return e, "tank" end
    end
    if cfg.boss then
        local e = findByName(cfg.boss)
        if e then return e, "boss" end
    end
    if all[1] then return all[1].obj, "boss" end
    return nil, nil
end

-- ============================================================
--  RAID RUNNER
-- ============================================================
local function runSingleRaid(raidName, isActiveFunc)
    ensureRaidConfig(raidName)
    local cfg       = Data.RaidConfig[raidName]
    local raidStart = tick()
    local noETimer  = 0
    local lastPhase = nil
    local phaseDesc = #cfg.light > 0 and ("Light: "..table.concat(cfg.light,", ")) or ""
    if cfg.tank then phaseDesc = phaseDesc..(phaseDesc~=""and" → "or"").."Tank: "..cfg.tank end
    phaseDesc = phaseDesc..(phaseDesc~=""and" → "or"").."Boss"
    WindUI:Notify({Title=string.format("[%s] Started",raidName), Content=phaseDesc, Duration=4})

    while isActiveFunc() do
        if State.pauseForGauntlet then
            break
        end
        if isRaidContinueVisible() then
            break
        end
        if tick()-raidStart > 900 then
            break
        end
        local target, tType = pickRaidTarget(raidName)
        if not target then
            noETimer += 0.3
            if noETimer >= 5 then
                break
            end
            task.wait(0.3) continue
        end
        noETimer = 0
        if tType ~= lastPhase then
            lastPhase = tType
            local msgs = {light="Clearing light...", tank="Attacking tank...", boss="Engaging boss!"}
        end
        local timeout   = tType=="light" and 5 or tType=="tank" and 8 or 20
        local tStart    = tick()
        local lastATick = 0
        while isActiveFunc() do
            if State.pauseForGauntlet then break end
            if isRaidContinueVisible() then break end
            if tick()-tStart > timeout then break end
            if not target or not target.Parent then break end
            if target:GetAttribute("dead") == true then break end
            if tType ~= "light" and #cfg.light > 0 then
                local hasLight = false
                for _, ln in ipairs(cfg.light) do
                    if findRaidEnemyByName(ln) then hasLight=true break end
                end
                if hasLight then break end
            end
            if tType == "boss" and cfg.tank and findRaidEnemyByName(cfg.tank) then break end
            local char  = player.Character
            local hrp   = char and char:FindFirstChild("HumanoidRootPart")
            local units = getMyUnits()
            local tPos  = getEnemyCFrame(target)
            if tPos and hrp then
                local dist = (hrp.Position - tPos.Position).Magnitude
                if dist <= CONST.RAID_MAX_RANGE then
                    if dist > 20 then
                        hrp.CFrame = tPos * CFrame.new(0,5,0)
                        hrp.AssemblyLinearVelocity = Vector3.zero
                    end
                    if tick()-lastATick >= 0.15 then
                        lastATick = tick()
                        teleportUnitsTo(tPos)
                        pcall(function() Remote.SendUnit:FireServer(target.Name, units) end)
                    end
                end
            end
            task.wait(0.08)
        end
    end
end

