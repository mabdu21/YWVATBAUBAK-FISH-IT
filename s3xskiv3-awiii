local function isGuiActuallyVisible(obj)
    local cur = obj
    while cur and cur ~= PlayerGui and cur ~= Svc.CoreGui do
        if cur:IsA("GuiObject") and not cur.Visible then return false end
        if cur:IsA("ScreenGui") and not cur.Enabled then return false end
        cur = cur.Parent
    end
    return true
end

local function clickObject(obj)
    local inset = Svc.GuiService:GetGuiInset()
    local cx = obj.AbsolutePosition.X + obj.AbsoluteSize.X / 2 + inset.X
    local cy = obj.AbsolutePosition.Y + obj.AbsoluteSize.Y / 2 + inset.Y
    Svc.VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, true,  game, 1)
    task.wait(0.05)
    Svc.VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, false, game, 1)
end

local function findJoinButton()
    for _, obj in ipairs(PlayerGui:GetDescendants()) do
        if obj:IsA("TextLabel") or obj:IsA("TextButton") then
            local ok, txt = pcall(function() return obj.Text end)
            if ok and string.lower(txt or "") == "join" then
                local vis = false
                pcall(function()
                    if obj.Visible and obj.Parent and obj.Parent.Visible and obj.AbsoluteSize.X > 0 then
                        vis = true
                    end
                end)
                if vis then return obj end
            end
        end
    end
    return nil
end

local function getInstanceCFrame(inst)
    if not inst then return nil end
    if inst:IsA("BasePart") then return inst.CFrame end
    if inst:IsA("Model") then
        local ok, cf = pcall(function() return inst:GetPivot() end)
        if ok and cf then return cf end
        if inst.PrimaryPart then return inst.PrimaryPart.CFrame end
    end
    for _, c in ipairs(inst:GetDescendants()) do
        if c:IsA("BasePart") then return c.CFrame end
    end
    return nil
end

