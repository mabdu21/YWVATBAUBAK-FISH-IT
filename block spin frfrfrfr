		-- เช็คว่า ATM พร้อมรับ deposit หรือยัง (เฉพาะ Janitor)
		if Config.AutoDepositJob and LOCKED_ATM_MAP[Config.SelectedJob] then
			local atmModel = GetJanitorLockedATMModel()
			if atmModel and not GetAtmIsNotHackedJob(atmModel) then
				-- ATM ยัง hacked อยู่ → กลับไปทำงานรอก่อน
				StateController.IsDepositing = false
				if not StateController.JobSystemActive then
					StateController:StartJob()
				end
				continue
			end
		end

		-- หา ATM ที่ใกล้ที่สุด
		local atmPos = GetDepositATMPos()

		if atmPos then
			-- teleport ไปจน dist <= 5 พร้อมเช็คว่า ATM ถูก hack กลางทางไหม
			local timeout = tick() + 10
			local atmHackedMidway = false
			while distTo(atmPos) > 5 and tick() < timeout do
				if Config.AutoDepositJob and LOCKED_ATM_MAP[Config.SelectedJob] then
					local atmModel = GetJanitorLockedATMModel()
					if atmModel and not GetAtmIsNotHackedJob(atmModel) then
						atmHackedMidway = true
						break
					end
				end
				Sf:Teleport(atmPos, true)
				task.wait(0.3)
			end

			if atmHackedMidway then
				-- ATM โดน hack กลางทาง → กลับไปทำงานรอก่อน
				StateController.IsDepositing = false
				if not StateController.JobSystemActive then
					StateController:StartJob()
				end
				continue
			end

			-- deposit
			local amt = Sf:GetMoney()
			if amt > 0 then
				Net.get("transfer_funds", "hand", "bank", amt)
				task.wait(0.5)
			end
		end

		-- resume job
		StateController.IsDepositing = false
		if not StateController.JobSystemActive then
			StateController:StartJob()
		end
	end
end)

func['StartFarmJob'] = function()
	while task.wait(0.2) do
		if not Config.StartFarmJob or not StateController.JobSystemActive then
			Sf:ForceStop()
			break
		end
		
		-- ⚡ เช็ค deposit ก่อนทำงานของ job
		CheckAndDeposit()
		
		local Jobs = Config.SelectedJob
		if Jobs == "None" then
			task.wait(1)
			continue
		end
		
		-- ========================================
		-- JANITOR JOB
		-- ========================================
		if Jobs == "Janitor" then
			if JobNow() ~= "janitor" then
				local dist = distTo(Vector3.new(110, 255, -309))
				if dist < 10 then
					Sf:Ac("apply_for_job", workspace:WaitForChild("BurgePlaceBeacon"))
				else
					Sf:Teleport(Vector3.new(110.824829, 255.190384, -309.609131), Config.StartFarmJob)
				end
			else
				-- ⚡ เช็คว่าควร deposit ไหม (แทนที่จะไปหา ATM ในงาน)
				local handMoney = Sf:GetMoney()
				if Config.AutoDepositJob and handMoney >= Config.DepositThreshold then
					-- ไม่ต้องไปหา ATM แบบเก่า — ให้ CheckAndDeposit() จัดการ
					-- skip puddle cleaning cycle นี้
					task.wait(1)
				else
					-- ทำงานปกติ
					if Character:FindFirstChild(FindBestTool('Janitor')) then
						local Level = Sf:GetSkill("Janitor")
						local PuddlesFolder = workspace.Map.Tiles.BurgerPlaceTile.BurgerPlace.Interior.Puddles
						local PuddleNear = GetNearThing(PuddlesFolder, "Puddle", function(puddle)
							local Large = puddle.Name == "LargePuddle"
							local OilPuddle = puddle.Name == "OilPuddle"
							local Toxic = puddle.Name == "ToxicPuddle"
							local Nasty = puddle.Name == "NastyPuddle"
							return puddle:IsA("BasePart") 
								and puddle.Size.Magnitude > 0.001 
								and puddle.Transparency < 1
								and (not Large or Level >= 5)
								and (not OilPuddle or Level >= 35)
								and (not Toxic or Level >= 50)
								and (not Nasty or Level >= 35)
						end)
						if not CheckingIsProgess() and PuddleNear then
							Sf:Teleport(PuddleNear.Position, Config.StartFarmJob)
							RootPart:PivotTo(CFrame.new(RootPart.CFrame.Position) * CFrame.Angles(0, math.rad(160), 0))
						end
					else
						if FindItem(FindBestTool('Janitor'))[1] then
							Humanoid:EquipTool(FindItem(FindBestTool('Janitor'))[2])
						end
					end
				end
			end
			
		-- ========================================
		-- QUICK-11 JOB
		-- ========================================
		elseif Jobs == "Quick-11" then
			if JobNow() ~= "shelf_stocker" then
				local dist = distTo(Vector3.new(133.074203, 255.315063, 208.3764049))
				if dist < 10 then
					Sf:Ac("apply_for_job", workspace.Map.Tiles.GasStationTile.Quick11.Interior.Quick11Beacon)
				elseif dist > 10 and dist < 500 then
					Sf:Teleport(Vector3.new(133.074203, 255.315063, 208.3764049), Config.StartFarmJob)
				else
					if Humanoid.Health > 0 then
						if not Client:GetAttribute('IsInCombat') then
							task.wait(2)
							Sf:Ac('request_respawn')
						end
					end
				end
			else
				local handMoney = Sf:GetMoney()
				
				-- ⚡ เช็คว่าควร deposit ไหม (แทนที่จะไปหา ATM ในงาน)
				if Config.AutoDepositJob and handMoney >= Config.DepositThreshold then
					task.wait(1)
				else
					local boxJob = workspace.Map.Tiles.GasStationTile.Quick11.Interior.ShelfStockingJob
					local boxTool = Backpack:FindFirstChild("BoxTool") or Character:FindFirstChild("BoxTool")
					
					if not boxTool then
						local normalBoxPos = Vector3.new(133.074203, 255.315063, 208.376404)
						local goldenBoxPos = Vector3.new(129.082565, 237.444138, 210.597443)
						if FindItem('Fists')[2] then Humanoid:UnequipTools() end
						
						if boxJob.GoldenBox.BillboardGui.Frame.StockLeft.Text ~= "Stock: 0/5 (x25)" and Config.GoldBox then
							if distTo(goldenBoxPos) < 5 then
								for i = 1, 5 do
									fireproximityprompt(boxJob.GoldenBox:FindFirstChild('ProximityPrompt'))
								end
							end
							Sf:Teleport(goldenBoxPos, Config.StartFarmJob)
						else
							if distTo(normalBoxPos) < 5 then
								for i = 1, 5 do
									fireproximityprompt(boxJob.NormalBox:FindFirstChild('ProximityPrompt'))
								end
							end
							Sf:Teleport(normalBoxPos, Config.StartFarmJob)
						end
					else
						local shelves = boxJob.Shelves
						if not Character:FindFirstChild("BoxTool") then
							Humanoid:EquipTool(boxTool)
						end
						repeat task.wait(0.2)
							Getunpack(shelves, function(v)
								if v:FindFirstChild("Attachment") then
									Sf:Teleport(v.Position, Config.StartFarmJob)
									RootPart:PivotTo(CFrame.new(RootPart.CFrame.Position) * CFrame.Angles(0, math.rad(160), 0))
								end
							end)
						until not Character:FindFirstChild("BoxTool") or not Config.StartFarmJob
					end
				end
			end
		end
	end
	
	StateController.JobSystemActive = false
	Sf:ForceStop()
end

