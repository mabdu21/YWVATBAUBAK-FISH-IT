				table.insert(keys, k)
			end
			table.sort(keys)
			if keys[3] and atm:GetAttribute(keys[3]) == false then
				local d = self:dist(atm.Area.CFrame)
				if d < shortestDist then
					closestATM = atm
					shortestDist = d
				end
			end
		end
	end
	return closestATM
end

