function StateController:StopJob()
	self.JobSystemActive = false
	Config.StartFarmJob = false
	if self.JobCoroutine then
		local s = coroutine.status(self.JobCoroutine)
		if s == "running" or s == "suspended" then pcall(task.cancel, self.JobCoroutine) end
		self.JobCoroutine = nil
	end
	Sf:ForceStop()
	ClearPathLines()
end

function StateController:StartJob()
	if self.JobSystemActive then return end
	self.JobSystemActive = true
	Config.StartFarmJob = true
	if not self.JobCoroutine or coroutine.status(self.JobCoroutine) == "dead" then
		self.JobCoroutine = task.spawn(function()
			if func['StartFarmJob'] then func['StartFarmJob']() end
		end)
	end
end

