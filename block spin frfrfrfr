local LOCKED_ATM_MAP = {
	["Janitor"] = JANITOR_ATM_CFRAME,
}

local function GetDepositATMPos()
	if Config.AutoDepositJob then
		local cf = LOCKED_ATM_MAP[Config.SelectedJob]
		if cf then return cf.Position end
	end
	local shortestDist, atmPos = math.huge, nil
	for _, atm in ipairs(GetAllATM()) do
		local pos = atm.PrimaryPart and atm.PrimaryPart.Position
		if not pos then
			for _, part in ipairs(atm:GetDescendants()) do
				if part:IsA("BasePart") then pos = part.Position break end
			end
		end
		if pos then
			local d = distTo(pos)
			if d < shortestDist then shortestDist = d atmPos = pos end
		end
	end
	return atmPos
end

local function CheckAndDeposit()
	if not Config.AutoDepositJob then return end
	local handMoney = Sf:GetMoney()
	if handMoney < Config.DepositThreshold then return end
	
	-- cooldown 30 วินาที (ไม่งั้นมันจะ spam deposit)
	if tick() - StateController.LastDepositTime < 30 then return end
	
	print("[Deposit] Hand: $" .. handMoney .. " → going to ATM")
	
	local atmPos = GetDepositATMPos()
	
	if atmPos then
		-- teleport ไปจน dist <= 8
		local timeout = tick() + 15
		while distTo(atmPos) > 8 and tick() < timeout and Config.StartFarmJob do
			Sf:Teleport(atmPos, Config.StartFarmJob)
			task.wait(0.5)
		end
		
		-- deposit
		local amt = Sf:GetMoney()
		if amt > 0 then
			print("[Deposit] Transferring $" .. amt)
			Net.get("transfer_funds", "hand", "bank", amt)
			task.wait(0.5)
			StateController.LastDepositTime = tick()
		end
	end
end

