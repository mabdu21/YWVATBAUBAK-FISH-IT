    end
end

local function IsATMAvailable(atm)
    local keys = {}
    for k in pairs(atm:GetAttributes()) do
        table.insert(keys, k)
    end
    table.sort(keys)

    if keys[3] and atm:GetAttribute(keys[3]) == false then
        return true
    end
    return false
end

