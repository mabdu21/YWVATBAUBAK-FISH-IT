ServerTab:Button(
    {
        Title = "Hop Server (Low Player)​",
        Icon = "shuffle",
        Callback = function()
            local HttpService = game:GetService("HttpService")
            local TeleportService = game:GetService("TeleportService")
            local servers = {}
            local req =
                game:HttpGet(
                string.format(
                    "https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100",
                    game.PlaceId
                )
            )
            local data = HttpService:JSONDecode(req)
            if data and data.data then
                for _, v in pairs(data.data) do
                    if v.playing < v.maxPlayers then
                        table.insert(servers, v.id)
                    end
                end
            end
            if #servers > 0 then
                TeleportService:TeleportToPlaceInstance(
                    game.PlaceId,
                    servers[math.random(1, #servers)],
                    game.Players.LocalPlayer
                )
            end
        end
    }
)

local FishingTab = Window:Tab({
    Title = 'Fishing',
    Icon = 'fishing-rod',
})

local FishingRods = {
    {Name = "FishingRodUltimate", Level = 60, Price = 5000},
    {Name = "FishingRodAdvanced", Level = 35, Price = 2300},
    {Name = "FishingRodPro", Level = 20, Price = 800},
    {Name = "FishingRodRegular", Level = 1, Price = 100}
}

local FishingBaits = {
    {Name = "PrawntecUltimate", Level = 45, Price = 45},
    {Name = "PrawntecPro", Level = 30, Price = 40},
    {Name = "PrawntecRegular", Level = 25, Price = 35},
    {Name = "WormtecUltimate", Level = 15, Price = 30},
    {Name = "WormtecPro", Level = 8, Price = 25},
    {Name = "WormtecRegular", Level = 1, Price = 20}
}

Config.AutoFarmFishing = false
Config.FishingRod = "Smart Select"
Config.FishingWormtec = "Smart Select"
Config.FishingBaitAmount = 1

FishingTab:Section({ Title = "Auto Farm:" })

FishingTab:Toggle({
    Title = "Auto Farm Fishing",
    Icon = "check",
    Type = "Checkbox",
    Value = false,
    Callback = function(Value)
        Config.AutoFarmFishing = Value
        if Value then
            task.spawn(function()
                while Config.AutoFarmFishing do
                    task.wait(1)
                    
                    local fishingLevel = Sf:GetSkill("Fishing")
                    
                    local targetRod = Config.FishingRod
                    if targetRod == "Smart Select" then
                        for _, rod in ipairs(FishingRods) do
                            if fishingLevel >= rod.Level then
                                targetRod = rod.Name
                                break
                            end
                        end
                    end
                    
                    local targetBait = Config.FishingWormtec
                    if targetBait == "Smart Select" then
                        for _, bait in ipairs(FishingBaits) do
                            if fishingLevel >= bait.Level then
                                targetBait = bait.Name
                                break
                            end
                        end
                    end
                    
                    local hasRod = false
                    local hasBait = false
                    local rodUid = nil
                    local baitUid = nil
                    local actualRodName = targetRod
                    local rodEquipped = false
                    
                    local Items = PlayerGui:FindFirstChild("Items")
                    if Items then
                        local Holding = Items:FindFirstChild("ItemsHolder") and Items.ItemsHolder:FindFirstChild("ItemsScrollingFrame")
                        if Holding then
                            for _, v in pairs(Holding:GetChildren()) do
                                if v.Name ~= 'Folder' and v.Name ~= 'UIGridLayout' and v.Name ~= "ItemTemplate" then
                                    local itemName = v:FindFirstChild("ItemName")
                                    if itemName and itemName.Text then
                                        local t = string.lower(itemName.Text)
                                        if not hasRod and string.find(t, "rod") then
                                            hasRod = true
                                            rodUid = v.Name
                                            actualRodName = itemName.Text
                                            local eq = v:FindFirstChild("ItemEquipped")
                                            rodEquipped = eq and eq.Visible or false
                                        end
                                        if not hasBait and (string.find(t, "wormtec") or string.find(t, "prawntec")) then
                                            hasBait = true
                                            baitUid = v.Name
                                        end
                                    end
                                end
                            end
                        end
                    end
                    
                    if hasRod and hasBait then
                        Sf:Teleport(Vector3.new(184.753616, 254.942337, -751.416321), Config.AutoFarmFishing)
                        task.wait(0.01)
                        
                        if rodUid and baitUid then
                            if not rodEquipped then
                                Net.get("toggle_equip_item", tostring(rodUid))
                                task.wait(0.01)
                                
                                local char = Client and Client.Character
                                local backpack = Client and Client:FindFirstChild("Backpack")
                                if char and backpack then
                                    local tool = backpack:FindFirstChild(actualRodName)
                                    local humanoid = char:FindFirstChildOfClass("Humanoid")
                                    if tool and humanoid then
                                        humanoid:EquipTool(tool)
                                        task.wait(0.01)
                                    end
                                end
                            end
                            
                            Net.get("equip_ammo_on_item", rodUid, baitUid)
                            task.wait(0.01)
                            
                            local char = Client and Client.Character
                            if char then
                                local rodTool = char:WaitForChild(actualRodName, 5)
                                if rodTool then
                                    Net.get("throw_rod", rodTool, Vector3.new(183.10549926757812, 249.84375, -761.474365234375))
                                    
                                    local timeout = tick() + 30
                                    local progressBarVisible = false
                                    
                                    while Config.AutoFarmFishing and tick() < timeout do
                                        task.wait()
                                        local sliderGui = PlayerGui:FindFirstChild("SliderMinigame")
                                        if sliderGui then
                                            local frame = sliderGui:FindFirstChildOfClass("Frame")
                                            if frame and frame.Visible then
                                                progressBarVisible = true
                                                break
                                            end
                                        end
                                    end
                                    
                                    if progressBarVisible then
                                        task.wait(0.01)
                                        Net.send("reel_ended", rodTool, true)
                                    end
                                end
                            end
                            task.wait(0.01)
                        end
                    else

                        local fishesToSell = {}
                        local currentItems = PlayerGui:FindFirstChild("Items")
                        if currentItems then
                            local holding = currentItems:FindFirstChild("ItemsHolder") and currentItems.ItemsHolder:FindFirstChild("ItemsScrollingFrame")
                            if holding then
                                for _, v in pairs(holding:GetChildren()) do
                                    if v.Name ~= 'Folder' and v.Name ~= 'UIGridLayout' and v.Name ~= "ItemTemplate" then
                                        local itemType = v:GetAttribute("ItemType")
                                        if itemType and string.lower(tostring(itemType)) == "fish" then
                                            table.insert(fishesToSell, v.Name)
                                        end
                                    end
                                end
                            end
                        end
                        
                        if #fishesToSell > 0 then
                            local sellBeacon = workspace:FindFirstChild("SellFishBeacon")
                            local touchPart = sellBeacon and sellBeacon:FindFirstChild("TouchPart")
                            if touchPart then
                                Sf:Teleport(touchPart.Position, Config.AutoFarmFishing)
                                task.wait(0.01)
                                
                                for _, fUid in ipairs(fishesToSell) do
                                    Net.get("sell_item", tostring(fUid), 1)
                                    task.wait(0.01)
                                end
                                task.wait(0.5)
                            end
                        end
                        
                        local baitAmt = Config.FishingBaitAmount or 1
                        local moneyNeeded = 0
                        if not hasRod then
                            for _, rod in ipairs(FishingRods) do
                                if rod.Name == targetRod then moneyNeeded = moneyNeeded + rod.Price break end
                            end
                        end
                        if not hasBait then
                            for _, bait in ipairs(FishingBaits) do
                                if bait.Name == targetBait then moneyNeeded = moneyNeeded + (bait.Price * baitAmt) break end
                            end
                        end
                        
                        while Sf:GetMoney() < moneyNeeded and Config.AutoFarmFishing do
                            local shortestDist = math.huge
                            local atmPos = nil
                            local targetAtm = nil
                            local ATMFolder = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Props") and workspace.Map.Props:FindFirstChild("ATMs")
                            if ATMFolder then
                                for _, atm in ipairs(ATMFolder:GetChildren()) do
                                    if atm.Name == "ATM" and GetAtmIsNotHackedJob(atm) then
                                        local pos = atm.PrimaryPart and atm.PrimaryPart.Position
                                        if not pos then
                                            for _, part in ipairs(atm:GetDescendants()) do
                                                if part:IsA("BasePart") then pos = part.Position break end
                                            end
                                        end
                                        if pos then
                                            local d = (pos - RootPart.Position).Magnitude
                                            if d < shortestDist then
                                                shortestDist = d
                                                atmPos = pos
                                                targetAtm = atm
                                            end
                                        end
                                    end
                                end
                            end
                            
                            if not atmPos then
                                atmPos = Vector3.new(179.200882, 255.290543, -236.355896)
                            end
                            
                            if atmPos then
                                local reached = false
                                local monitorThread = task.spawn(function()
                                    while not reached and Config.AutoFarmFishing do
                                        task.wait(0.2)
                                        if targetAtm and not GetAtmIsNotHackedJob(targetAtm) then
                                            Sf:ForceStop()
                                            break
                                        end
                                    end
                                end)
                                
                                Sf:Teleport(atmPos, Config.AutoFarmFishing)
                                reached = true
                                
                                if (targetAtm and GetAtmIsNotHackedJob(targetAtm)) or not targetAtm then
                                    local hrp = Character:FindFirstChild("HumanoidRootPart")
                                    if hrp and (hrp.Position - atmPos).Magnitude < 25 then
                                        local needed = moneyNeeded - Sf:GetMoney()
                                        if needed > 0 then
                                            Net.get("transfer_funds", "bank", "hand", needed)
                                            task.wait(0.5)
                                        end
                                    end
                                end
                            else
                                task.wait(1)
                            end
                        end
                        
                        local shopPos = Vector3.new(-136.406662, 254.851074, 153.555588)
                        Sf:Teleport(shopPos, Config.AutoFarmFishing)
                        task.wait(0.01)
                        
                        if not hasRod then
                            Net.get("purchase_consumable", workspace:WaitForChild("ShopZone_Hardware"), targetRod)
                            task.wait(0.01)
                        end
                        if not hasBait then
                            local baitAmt = Config.FishingBaitAmount or 1
                            for i = 1, baitAmt do
                                Net.get("purchase_consumable", workspace:WaitForChild("ShopZone_Hardware"), targetBait)
                                task.wait(0.05)
                            end
                        end
                    end
                end
            end)
        end
    end,
})

