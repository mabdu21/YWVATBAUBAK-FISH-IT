local autoEquipActive = false 
local fakeTools = {} -- เก็บโมเดลจำลองไว้ลบตอนปิด Toggle

-- ฟังก์ชันสำหรับทำลายเบ็ดจำลองเมื่อปิดใช้งาน
local function clearFakeTools()
    for _, obj in ipairs(fakeTools) do
        if obj then obj:Destroy() end
    end
    fakeTools = {}
end

FishingTab:Toggle({
    Title = "Auto Equip FishingRod",
    Desc = "",
    Value = false,
    Callback = function(v)
        autoEquipActive = v
        print("Toggle:", v)
        
        if not autoEquipActive then
            clearFakeTools() -- ปิด Toggle ให้ลบเบ็ดที่งอกออกมาออกไป
        end
        
        if autoEquipActive then
            task.spawn(function()
                while autoEquipActive do
                    local player = game.Players.LocalPlayer
                    local character = player.Character or player.CharacterAdded:Wait()
                    local backpack = player:FindFirstChild("Backpack")
                    local humanoid = character:FindFirstChildOfClass("Humanoid")
                    local rArm = character:FindFirstChild("RightHand") or character:FindFirstChild("Right Arm")
                    
                    local toolNames = {
                        "FishingRodUltimate",
                        "FishingRodAdvanced",
                        "FishingRodPro",
                        "FishingRodRegular"
                    }
                    
                    if backpack and humanoid and rArm then
                        -- 1. ค้นหาเบ็ดหลักชิ้นแรกที่จะเอามาถือจริง ๆ (เพื่อให้ระบบเกมรับรู้ว่าถือไอเทมอยู่)
                        local mainTool = nil
                        for _, name in ipairs(toolNames) do
                            mainTool = character:FindFirstChild(name) or backpack:FindFirstChild(name)
                            if mainTool then break end
                        end
                        
                        if mainTool and mainTool.Parent == backpack then
                            humanoid:EquipTool(mainTool) -- ถือเบ็ดหลัก
                        end
                        
                        -- 2. นำเบ็ดชิ้นอื่น ๆ ที่เหลือในกระเป๋ามาเชื่อมติดกับมือขวาเพื่อให้ออกมาพร้อมกันทั้งหมด
                        for _, name in ipairs(toolNames) do
                            local tool = backpack:FindFirstChild(name)
                            -- ต้องไม่ใช่เบ็ดหลักที่ถืออยู่ และต้องยังไม่มีโมเดลจำลองของชิ้นนี้
                            if tool and tool ~= mainTool and not character:FindFirstChild(name .. "_Fake") then
                                -- คัดลอก Handle ของเบ็ดชิ้นอื่นมา
                                local handle = tool:FindFirstChild("Handle")
                                if handle then
                                    local fakeHandle = handle:Clone()
                                    fakeHandle.Name = name .. "_Fake"
                                    fakeHandle.CanCollide = false
                                    fakeHandle.Parent = character
                                    
                                    -- สร้าง Weld เพื่อเชื่อมโมเดลเข้ากับมือของตัวละคร
                                    local weld = Instance.new("WeldConstraint")
                                    weld.Part0 = rArm
                                    weld.Part1 = fakeHandle
                                    weld.Parent = fakeHandle
                                    
                                    -- ตั้งตำแหน่งให้อยู่ที่มือ (สามารถปรับเยื้องตำแหน่งตามต้องการได้)
                                    fakeHandle.CFrame = rArm.CFrame
                                    
                                    table.insert(fakeTools, fakeHandle)
                                end
                            end
                        end
                    end
                    task.wait(1) -- เช็คทุกๆ 1 วินาทีเพื่ออัปเดตหากตัวละครตายแล้วเกิดใหม่
                end
            end)
        end
    end
})