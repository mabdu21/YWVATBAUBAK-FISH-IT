local function GetNearThing(folder, path, condition)
	local closest, shortestDist = nil, math.huge
	if not folder then return nil end
	for _, obj in ipairs(folder:GetChildren()) do
		if string.find(obj.Name, path) then
			if not condition or condition(obj) then
				local dist = math.huge
				if obj:IsA("BasePart") then dist = distTo(obj.Position)
				elseif obj:IsA('Model') and obj.PrimaryPart then dist = distTo(obj.PrimaryPart.Position) end
				if dist < shortestDist then closest = obj shortestDist = dist end
			end
		end
	end
	return closest
end

